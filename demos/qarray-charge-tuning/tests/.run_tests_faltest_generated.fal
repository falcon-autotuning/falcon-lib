import (
"../../../libs/testing/testing.fal"
"../../../libs/database/database.fal"
"../../../libs/strings/strings.fal"
"../../../libs/collections/array/array.fal"
"../../../libs/collections/map/map.fal"
"../../../libs/falconCore/generic/farray/farray.fal"
"../../../libs/falconCore/physics/units/symbolUnit/symbolUnit.fal"
"../../../libs/falconCore/communications/voltageStates/deviceVoltageStates/deviceVoltageStates.fal"
"../../../libs/falconCore/physics/deviceStructures/connections/connections.fal"
"../../../libs/falconCore/communications/voltageStates/deviceVoltageStates/deviceVoltageStates.fal"
"../hub.fal"
"../chargeConfigurationTuner.fal"
)

// ─────────────────────────────────────────────────────────────────────────────
// Suite 1: FirstTest 
// ─────────────────────────────────────────────────────────────────────────────
autotuner FirstTest -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_symmetrical(TestRunner runner, TestContext t) {
        // Call our yaml file
        hub::RestartDevice("../2_dot.yml");
        // Reset the database
        database::InitializeSchema();
        database::ClearAll();
        // Generate stability diagram plot
        hub::MakeStabilityDiagram("./stability_diagram_2_dot.png");
        // Set the global variables for the autotuning 
        // 1. Build a virtualization matrix 
        farray::FArray virtualization;
        virtualization = hub::BuildVirtualizationMatrix("../2_dot.yml");
        database::DeviceCharacteristic dcharVirtualization;
        dcharVirtualization = database::DeviceCharacteristic.New()
            .SetScope("device")
.SetName("virtualization")
            .SetValue(virtualization.ToJSON());
        database::Insert(dcharVirtualization);
        // 2. Build the resolution variable
        int resolution = 100;
        database::DeviceCharacteristic dcharResolution = database::DeviceCharacteristic.New()
            .SetScope("device")
            .SetName("resolution")
            .SetValue(strings::FromInt(resolution));
        database::Insert(dcharResolution);
        // 3. Build the virualization names variable
        array::Array<connection::Connection> rawPlungerGates = hub::CollectCurrentPlungerGates(); 
        connections::Connections virtualizationNames = connections::Connections.New(rawPlungerGates);
        database::DeviceCharacteristic dcharVirtualizationNames = database::DeviceCharacteristic.New()
            .SetScope("device")
            .SetName("virtualizationNames")
            .SetValue(virtualizationNames.ToJSON());
        database::Insert(dcharVirtualizationNames);
        // 4. Build the interdotSpacing variable
        Quantity interdotSpacing = Quantity.New(0.1, symbolUnit::SymbolUnit.Volt());
        database::DeviceCharacteristic dcharInterdotSpacing = database::DeviceCharacteristic.New()
            .SetScope("device")
            .SetName("interdotSpacing")
            .SetPlungerGate(rawPlungerGates[0])
            .SetValue(interdotSpacing.ToJSON());
        database::Insert(dcharInterdotSpacing);
        database::DeviceCharacteristic dcharInterdotSpacing = database::DeviceCharacteristic.New()
            .SetScope("device")
            .SetName("interdotSpacing")
            .SetPlungerGate(rawPlungerGates[1])
            .SetValue(interdotSpacing.ToJSON());
        database::Insert(dcharInterdotSpacing);
        // 5. Define the starting position 
        Map<connection::Connection, quantity::Quantity> begin = Map.New();
        begin.Set(rawPlungerGates[0], quantity::Quantity.New(-200.0, symbolUnit::SymbolUnit.Millivolt()));
        begin.Set(rawPlungerGates[1], quantity::Quantity.New(-200.0, symbolUnit::SymbolUnit.Millivolt()));
        hub::Ramp(begin);
        // 6. Run the charge tuning autotuner
        deviceVoltageStates::DeviceVoltageStates theEndState = chargeConfigurationTuner::ChargeConfigurationTuner(3,3); 
        // 7. Check the end state is correct by making sure we are in the (3,3) cell of the stability diagram
        // TODO: write this  check
        Error err = t.ExpectTrue(true, "Made it all the way through");
        -> __end(runner, t);
    }

  // ── Harness (generated by falcon-test — do not edit) ──────────────
  state __init {
    TestRunner runner = TestRunner.New("FirstTest");
    Error err = runner.Register("test_symmetrical");
    err = runner.PrintHeader();
    -> __loop(runner);
  }

  state __loop (TestRunner runner) {
    bool more = runner.HasNext();
    if (more) { -> __begin(runner);}
    else      { -> __finish(runner);}
  }

  state __begin (TestRunner runner) {
    TestContext t = runner.BeginCurrent();
    -> __dispatch(runner, t);
  }

  state __dispatch (TestRunner runner, TestContext t) {
    string name = runner.CurrentName();
    if (name == "test_symmetrical") { -> test_symmetrical(runner, t); }
    Error err = t.Fail("no body for: " + name);
    -> __end(runner, t);
  }

  state __end (TestRunner runner, TestContext t) {
    Error err = runner.EndCurrent(t);
    -> __loop(runner);
  }

  state __finish (TestRunner runner) {
    Error err = runner.PrintSummary();
    passed = runner.PassedCount();
    failed = runner.FailedCount();
    terminal;
  }
}
