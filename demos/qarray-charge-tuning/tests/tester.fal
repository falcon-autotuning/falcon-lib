ffimport "../qarray-wrapper.cpp" (
  "-I/opt/falcon/include"
  "-I/opt/falcon/include/python3.12"
) (
  "-L/opt/falcon/lib"
  "-lfalcon-qarrayDevice"
  "-lplplot"
  "-lm"
  "-lpthread"
  "-lpython3.12"
)
// Allows restarting of the qarray simlator from the tester
routine RestartDevice(string configPath) -> ()
// Makes a stablity diagram plot of the device 
routine MakeStabilityDiagram(string outputFilepath) -> ()
// Builds a virtualization matrix for the device given a set of plunger gates and a set of virtual gates
routine BuildVirtualizationMatrix(string configPath) -> (FArray virtualization)

