import (
"../../libs/falconCore/communications/voltageStates/deviceVoltageStates/deviceVoltageStates.fal"
"../../libs/collections/map/map.fal"
"../../libs/falconCore/math/quantity/quantity.fal"
"../../libs/falconCore/physics/deviceStructures/connection/connection.fal"
)
ffimport "qarray-wrapper.cpp" (
  "-I/opt/falcon/include"
  "-I/opt/falcon/include/python3.12"
) (
  "-L/opt/falcon/lib"
  "-lfalcon-qarrayDevice"
  "-lplplot"
  "-lm"
  "-lpthread"
