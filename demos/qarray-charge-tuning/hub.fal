// Collects the current device gate voltages
routine CollectCurrentDeviceState() -> (deviceVoltageStates::DeviceVoltageStates dstates)
// Collects the current plunger gates 
routine CollectCurrentPlungerGates() -> (array::Array<connection::Connection> gates)
// Ramps the device to the supplied end voltage 
routine Ramp(map::Map<connection::Connection, quantity::Quantity> stop) -> ()
// Analyze if a blip is there or not
routine AnalyzeBlips(map::Map<connection::Connection, quantity::Quantity> begin, map::Map<connection::Connection, quantity::Quantity> stop, int resolution) -> (int num_blips, Array<deviceVoltageStates::DeviceVoltageStates> locations)
// Calculates a device state given a virtualization matrix, spacing in a direction
routine EndState(Connection direction, Quantity spacing, FArray virtualization, Connections virtualNames) -> (Point endstate)
