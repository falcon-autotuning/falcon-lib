{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Falcon Device Characteristics Snapshot",
  "description": "A snapshot of device characteristics from the Falcon database",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "name",
      "hash",
      "recordtime"
    ],
    "properties": {
      "scope": {
        "type": "string",
        "description": "Scope identifier for the characteristic"
      },
      "name": {
        "type": "string",
        "description": "Name of the device characteristic"
      },
      "barrier_gate": {
        "type": "string",
        "description": "Barrier gate identifier"
      },
      "plunger_gate": {
        "type": "string",
        "description": "Plunger gate identifier"
      },
      "reservoir_gate": {
        "type": "string",
        "description": "Reservoir gate identifier"
      },
      "screening_gate": {
        "type": "string",
        "description": "Screening gate identifier"
      },
      "extra": {
        "type": "string",
        "description": "Additional metadata"
      },
      "uncertainty": {
        "type": "number",
        "description": "Uncertainty value (0.0-1.0)",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "hash": {
        "type": "string",
        "description": "Hash identifier for the characteristic"
      },
      "recordtime": {
        "type": "integer",
        "description": "Unix timestamp of record creation"
      },
      "device_state": {
        "type": "string",
        "description": "State of the device when characteristic was recorded"
      },
      "unit_name": {
        "type": "string",
        "description": "Unit of measurement"
      },
      "device_characteristic": {
        "description": "The actual characteristic value",
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "boolean"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "string"
          }
        ]
      }
    }
  }
}
