# ==============================================================================
# Tree-sitter grammar for Falcon DSL (.fal)
# ==============================================================================
# Prerequisites: Node.js >= 18, npm, gcc
# Install tree-sitter CLI:   npm install -g tree-sitter-cli
#                        or: npm install  (uses local devDependency)
#
# Quick-start for local Neovim dev:
#   make nvim-dev          – generate + compile + deploy parser + queries + lua
#   make test              – run corpus tests
# ==============================================================================

TREE_SITTER ?= tree-sitter

# Language name — must match grammar.js name: 'falcon' and Neovim registration
LANG = falcon

# Neovim paths (override with: make nvim-dev NVIM_PARSER_DIR=...)
NVIM_PARSER_DIR  ?= $(HOME)/.local/share/nvim/site/parser
NVIM_QUERY_DIR   ?= $(HOME)/.config/nvim/queries/$(LANG)
NVIM_LUA_DIR     ?= $(HOME)/.config/nvim/lua/plugins

# Compiler settings
CC      ?= gcc
CFLAGS  ?= -O2 -shared -fPIC -fno-exceptions
INCLUDE  = -I ./src

PARSER_SOURCES = src/parser.c
PARSER_SO      = $(LANG).so

# Names of the two Lua files written into NVIM_LUA_DIR
NVIM_TS_LUA     = $(NVIM_LUA_DIR)/falcon-treesitter.lua
NVIM_HL_LUA     = $(NVIM_LUA_DIR)/falcon-highlights.lua

.PHONY: all install generate build-so test test-filter parse highlight lint \
        nvim-install nvim-install-queries nvim-install-lua nvim-dev clean help

all: install generate test

# ------------------------------------------------------------------------------

## install               – Install Node dependencies
install:
	npm install

## generate              – Regenerate src/parser.c from grammar.js
generate: grammar.js
	$(TREE_SITTER) generate
	@echo "✔ parser.c generated in src/"

## build-so              – Compile src/parser.c → falcon.so
build-so: $(PARSER_SOURCES)
	$(CC) $(CFLAGS) $(INCLUDE) -o $(PARSER_SO) $(PARSER_SOURCES)
	@echo "✔ $(PARSER_SO) compiled"

## test                  – Run tree-sitter corpus tests
test:
	$(TREE_SITTER) test
	@echo "✔ all corpus tests passed"

## test-filter           – Run only tests matching FILTER=<pattern>
##                         Usage: make test-filter FILTER="Autotuner"
test-filter:
	$(TREE_SITTER) test --filter "$(FILTER)"

## parse                 – Parse a .fal file for debugging
##                         Usage: make parse FILE=path/to/file.fal
parse:
	$(TREE_SITTER) parse $(FILE)

## highlight             – Test highlights on a .fal file (terminal output)
##                         Usage: make highlight FILE=path/to/file.fal
highlight:
	$(TREE_SITTER) highlight $(FILE)

## lint                  – Check grammar.js for basic issues
lint: grammar.js
	$(TREE_SITTER) generate --report-states-for-rule program
	@echo "✔ grammar lint OK"

# ------------------------------------------------------------------------------
# Neovim integration
# ------------------------------------------------------------------------------

## nvim-install          – Compile and deploy falcon.so to Neovim's parser dir
nvim-install: build-so
	@mkdir -p $(NVIM_PARSER_DIR)
	cp $(PARSER_SO) $(NVIM_PARSER_DIR)/$(PARSER_SO)
	@echo "✔ $(PARSER_SO) → $(NVIM_PARSER_DIR)/$(PARSER_SO)"

## nvim-install-queries  – Deploy queries/highlights.scm → Neovim query dir
nvim-install-queries:
	@mkdir -p $(NVIM_QUERY_DIR)
	cp queries/falcon/highlights.scm $(NVIM_QUERY_DIR)/highlights.scm
	@echo "✔ highlights.scm → $(NVIM_QUERY_DIR)/highlights.scm"

## nvim-install-lua      – Write falcon-treesitter.lua and falcon-highlights.lua
##                         into ~/.config/nvim/lua/plugins/.
##                         Uses separate files so existing autocmds.lua is
##                         never touched. Safe to run repeatedly.
nvim-install-lua:
	@mkdir -p $(NVIM_LUA_DIR)
	@# ── falcon-treesitter.lua ────────────────────────────────────────────────
	@printf '%s\n' \
	  '-- Auto-generated by: make nvim-install-lua' \
	  '-- Registers the Falcon DSL tree-sitter parser with Neovim/LazyVim.' \
	  '-- Do not edit by hand — re-run make nvim-install-lua to regenerate.' \
	  'return {' \
	  '  {' \
	  '    "nvim-treesitter/nvim-treesitter",' \
	  '    opts = function(_, opts)' \
	  '      vim.filetype.add({ extension = { fal = "falcon" } })' \
	  '      vim.treesitter.language.add("falcon", {' \
	  '        path = vim.fn.expand("$(NVIM_PARSER_DIR)/falcon.so"),' \
	  '      })' \
	  '      vim.treesitter.language.register("falcon", "falcon")' \
	  '      opts.highlight = opts.highlight or {}' \
	  '      opts.highlight.enable = true' \
	  '      return opts' \
	  '    end,' \
	  '  },' \
	  '  {' \
	  '    "nvim-treesitter/nvim-treesitter",' \
	  '    init = function()' \
	  '      vim.api.nvim_create_autocmd("FileType", {' \
	  '        pattern = "falcon",' \
	  '        callback = function(ev)' \
	  '          vim.treesitter.start(ev.buf, "falcon")' \
	  '        end,' \
	  '      })' \
	  '    end,' \
	  '  },' \
	  '}' \
	  > $(NVIM_TS_LUA)
	@echo "✔ falcon-treesitter.lua → $(NVIM_TS_LUA)"
	@# ── falcon-highlights.lua ────────────────────────────────────────────────
	@printf '%s\n' \
	  '-- Auto-generated by: make nvim-install-lua' \
	  '-- Wires Falcon DSL tree-sitter capture groups to the active colorscheme.' \
	  '-- Uses only `link` — no hardcoded hex. Automatically re-applies when' \
	  '-- the colorscheme changes. Safe alongside any existing autocmds.lua.' \
	  '' \
	  'local function set_falcon_highlights()' \
	  '  -- Helper: link `from` to `to` if `to` is defined, else fall back.' \
	  '  local function link(from, to, fallback)' \
	  '    local hl = vim.api.nvim_get_hl(0, { name = to, link = false })' \
	  '    if hl and not vim.tbl_isempty(hl) then' \
	  '      vim.api.nvim_set_hl(0, from, { link = to })' \
	  '    elseif fallback then' \
	  '      vim.api.nvim_set_hl(0, from, { link = fallback })' \
	  '    end' \
	  '  end' \
	  '' \
	  '  -- @type.definition: autotuner names ("Calculator") — Type + bold' \
	  '  local type_hl = vim.api.nvim_get_hl(0, { name = "Type", link = false })' \
	  '  vim.api.nvim_set_hl(0, "@type.definition",' \
	  '    vim.tbl_extend("force", type_hl, { bold = true }))' \
	  '' \
	  '  -- @function.method: state names ("calculate", "done") — Function + bold' \
	  '  local fn_hl = vim.api.nvim_get_hl(0, { name = "Function", link = false })' \
	  '  vim.api.nvim_set_hl(0, "@function.method",' \
	  '    vim.tbl_extend("force", fn_hl, { bold = true }))' \
	  '' \
	  '  -- Variable captures — all link to the same base for consistency.' \
	  '  -- sum/product/a/b look identical wherever they appear.' \
	  '  link("@variable",           "Identifier",  "Normal")' \
	  '  link("@variable.parameter", "@variable",   "Identifier")' \
	  '  link("@variable.builtin",   "@variable",   "Identifier")' \
	  '' \
	  '  -- Transition / entry targets' \
	  '  link("@label",              "Label",       "Special")' \
	  '' \
	  '  -- Keyword subcategories' \
	  '  link("@keyword.return",       "@keyword",    "Keyword")' \
	  '  link("@keyword.operator",     "Operator",    "Keyword")' \
	  '  link("@keyword.conditional",  "Conditional", "@keyword")' \
	  '' \
	  '  -- Standard groups — ensure they exist for older Neovim builds' \
	  '  link("@type",                 "Type",        "Identifier")' \
	  '  link("@function",             "Function",    "Identifier")' \
	  '  link("@function.call",        "Function",    "Identifier")' \
	  '  link("@property",             "Identifier",  "Normal")' \
	  '  link("@comment",              "Comment",     "NonText")' \
	  '  link("@string",               "String",      "Normal")' \
	  '  link("@number",               "Number",      "Constant")' \
	  '  link("@number.float",         "Float",       "@number")' \
	  '  link("@boolean",              "Boolean",     "@number")' \
	  '  link("@constant.builtin",     "Special",     "Constant")' \
	  '  link("@operator",             "Operator",    "Normal")' \
	  '  link("@punctuation.bracket",  "Delimiter",   "Normal")' \
	  '  link("@punctuation.delimiter","Delimiter",   "Normal")' \
	  'end' \
	  '' \
	  'set_falcon_highlights()' \
	  '' \
	  'vim.api.nvim_create_autocmd("ColorScheme", {' \
	  '  pattern = "*",' \
	  '  callback = set_falcon_highlights,' \
	  '})' \
	  '' \
	  'return {}' \
	  > $(NVIM_HL_LUA)
	@echo "✔ falcon-highlights.lua → $(NVIM_HL_LUA)"

## nvim-dev              – Full dev cycle: generate + compile + deploy all
nvim-dev: generate nvim-install nvim-install-queries nvim-install-lua
	@echo ""
	@echo "════════════════════════════════════════════════════════"
	@echo "  Falcon tree-sitter fully deployed to Neovim"
	@echo "  Parser : $(NVIM_PARSER_DIR)/$(PARSER_SO)"
	@echo "  Queries: $(NVIM_QUERY_DIR)/highlights.scm"
	@echo "  Lua    : $(NVIM_TS_LUA)"
	@echo "  Lua    : $(NVIM_HL_LUA)"
	@echo "════════════════════════════════════════════════════════"
	@echo "  Restart Neovim and open a .fal file."

## clean                 – Remove generated and compiled files
clean:
	rm -rf src/parser.c src/tree_sitter/ node_modules/ build/
	rm -f $(PARSER_SO)
	@echo "✔ cleaned"

## help                  – Show this help message
help:
	@grep -E '^## ' Makefile | sed 's/## /  /'
