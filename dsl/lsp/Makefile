# ==============================================================================
# Falcon LSP for Falcon DSL (.fal)
# ==============================================================================
# Prerequisites: cmake, ninja, clang, /opt/falcon installed
#
# Quick-start for local Neovim dev (LazyVim):
#   make nvim-install      – deploy Lua plugin to ~/.config/nvim/lua/plugins/
# ==============================================================================

# Neovim paths (override with: make nvim-install NVIM_LUA_DIR=...)
NVIM_LUA_DIR ?= $(HOME)/.config/nvim/lua/plugins

# Name of the Lua plugin file written into NVIM_LUA_DIR
NVIM_LSP_LUA = $(NVIM_LUA_DIR)/falcon-lsp.lua

# LSP binary installed by the build system
LSP_BIN ?= /opt/falcon/lib/falcon-lsp

.PHONY: nvim-install clean help

## nvim-install   – Deploy falcon-lsp LazyVim plugin to Neovim lua/plugins/
##                  Writes falcon-lsp.lua that registers falcon-lsp with
##                  nvim-lspconfig and sets up keymaps for .fal files.
##                  Safe to run repeatedly; existing file is overwritten.
nvim-install:
	@mkdir -p $(NVIM_LUA_DIR)
	@# Copy the pre-written Lua configuration
	cp neovim/falcon_lsp.lua $(NVIM_LUA_DIR)/falcon_lsp.lua
	@# Write a LazyVim plugin spec that loads falcon_lsp.lua automatically
	@printf '%s\n' \
	  '-- Auto-generated by: make nvim-install (autotuner/lsp/Makefile)' \
	  '-- Registers the Falcon DSL language server (falcon-lsp) with LazyVim.' \
	  '-- Do not edit by hand — re-run make nvim-install to regenerate.' \
	  'return {' \
	  '  {' \
	  '    "neovim/nvim-lspconfig",' \
	  '    config = function()' \
	  '      -- Ensure falcon_lsp.lua is on the runtime path' \
	  '      local plugin_dir = vim.fn.expand("$(NVIM_LUA_DIR)")' \
	  '      if not vim.tbl_contains(vim.opt.runtimepath:get(), plugin_dir) then' \
	  '        vim.opt.runtimepath:append(plugin_dir)' \
	  '      end' \
	  '      local ok, falcon_lsp = pcall(require, "falcon_lsp")' \
	  '      if ok then' \
	  '        falcon_lsp.setup({' \
	  '          on_attach = function(_, bufnr)' \
	  '            local opts = { buffer = bufnr, silent = true }' \
	  '            vim.keymap.set("n", "K",          vim.lsp.buf.hover,        opts)' \
	  '            vim.keymap.set("n", "gd",         vim.lsp.buf.definition,   opts)' \
	  '            vim.keymap.set("n", "<C-Space>",  vim.lsp.buf.completion,   opts)' \
	  '            vim.keymap.set("n", "<leader>rn", vim.lsp.buf.rename,       opts)' \
	  '            vim.keymap.set("n", "<leader>e",  vim.diagnostic.open_float, opts)' \
	  '          end,' \
	  '        })' \
	  '      end' \
	  '    end,' \
	  '  },' \
	  '}' \
	  > $(NVIM_LSP_LUA)
	@echo "✔ falcon_lsp.lua  → $(NVIM_LUA_DIR)/falcon_lsp.lua"
	@echo "✔ falcon-lsp.lua  → $(NVIM_LSP_LUA)"
	@echo ""
	@echo "Restart Neovim and open a .fal file."
	@echo "The LSP binary is expected at: $(LSP_BIN)"

## clean          – Remove generated Lua files
clean:
	rm -f $(NVIM_LSP_LUA) $(NVIM_LUA_DIR)/falcon_lsp.lua
	@echo "✔ cleaned"

## help           – Show this help message
help:
	@grep -E '^## ' Makefile | sed 's/## /  /'
