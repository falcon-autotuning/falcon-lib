autotuner Coercion() -> (int result) {
    bool completed = false;
    start -> init;

    state init {
        // String to int
        int from_str = int("42");
        log::Info("int from string: " + string(from_str));

        // String to float
        float pi = float("3.14");
        log::Info("float from string: " + string(pi));

        // String to bool
        bool flag = bool("true");
        log::Info("bool from string: " + string(flag));

        // Int to string
        string s = string(123);
        log::Info("string from int: " + s);

        result = from_str;
        terminal;
    }
}
