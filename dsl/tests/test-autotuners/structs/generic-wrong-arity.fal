// This file should FAIL to parse: Box expects 1 type arg, we give 2.
// Used to test that the parser rejects incorrect arity.

struct Box <T> {
    T value;
    routine New (T v) -> (Box<T> b) {
        b.value = v;
    }
}

autotuner GenericWrongArity (int x) -> (int result) {
    result = 0;
    start -> run;
    state run {
        Box<int, float> b = Box.New(x);   // ERROR: expects 1, got 2
        result = 0;
        terminal;
    }
}
