// Tests a two-type-param generic struct.
// struct Pair<A, B> holds two values of potentially different types.

struct Pair <A, B> {
    A first;
    B second;
    routine New (A a, B b) -> (Pair<A, B> p) {
        p.first  = a;
        p.second = b;
    }
    routine GetFirst  -> (A v) { v = this.first; }
    routine GetSecond -> (B v) { v = this.second; }
}

autotuner GenericPair (int a, string s) -> (int out_int, string out_str) {
    out_int = 0;
    out_str = "";
    start -> run;
    state run {
        Pair<int, string> p = Pair.New(a, s);
        out_int = p.GetFirst();
        out_str = p.GetSecond();
        terminal;
    }
}
