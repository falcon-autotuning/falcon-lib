// Tests a simple single-type-param generic struct.
// struct Box<T> wraps a single value of any type.

struct Box <T> {
    T value;
    routine New (T v) -> (Box<T> b) {
        b.value = v;
    }
    routine Get -> (T v) {
        v = this.value;
    }
}

autotuner GenericBoxInt (int x) -> (int result) {
    result = 0;
    start -> run;
    state run {
        Box<int> b = Box.New(x);
        result = b.Get();
        terminal;
    }
}
