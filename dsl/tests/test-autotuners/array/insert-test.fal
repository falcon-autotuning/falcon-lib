// Tests Array.insert(int, value): inserts a value at a given index.
// Input:  Array<int> arr, int insert_idx, int insert_val
// Output: int first, int second, int third  (all elements after insert)
autotuner InsertTest (Array<int> arr, int insert_idx, int insert_val) -> (int first, int second, int third) {
    first  = 0;
    second = 0;
    third  = 0;
    start -> run;

    state run {
        arr.insert(insert_idx, insert_val);
        first  = arr[0];
        second = arr[1];
        third  = arr[2];
        terminal;
    }
}
