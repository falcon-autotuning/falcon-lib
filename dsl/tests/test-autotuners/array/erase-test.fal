// Tests Array.erase(int): removes the element at a given index.
// Input:  Array<int> arr (passed as param), int erase_idx
// Output: int first, int second  (the two remaining elements after erase)
autotuner EraseTest (Array<int> arr, int erase_idx) -> (int first, int second) {
    first  = 0;
    second = 0;
    start -> run;

    state run {
        arr.erase(index = erase_idx);
        first  = arr[0];
        second = arr[1];
        terminal;
    }
}
