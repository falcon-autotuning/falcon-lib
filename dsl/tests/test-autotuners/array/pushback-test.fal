// Tests Array.pushback(value): appends a value to the end of the array.
// Input:  Array<int> arr (starts with 2 elements), int push_val
// Output: int last_element  (the newly pushed value at index 2)
autotuner PushbackTest (Array<int> arr, int push_val) -> (int last_element) {
    last_element = 0;
    start -> run;

    state run {
        arr.pushback(push_val);
        last_element = arr[arr.size() -1];
        terminal;
    }
}
