autotuner ConditionalChain (int value) -> (string category) {
  category = "";
  
  start -> classify;
  
  state classify {
    if (value < 0) {
      -> negative;
    }
    elif (value == 0) {
      -> zero;
    }
    elif (value < 10) {
      -> small;
    }
    elif (value < 100) {
      -> medium;
    }
    else {
      -> large;
    }
  }
  
  state negative {
    category = "negative";
    terminal;
  }
  
  state zero {
    category = "zero";
    terminal;
  }
  
  state small {
    category = "small";
    terminal;
  }
  
  state medium {
    category = "medium";
    terminal;
  }
  
  state large {
    category = "large";
    terminal;
  }
}
