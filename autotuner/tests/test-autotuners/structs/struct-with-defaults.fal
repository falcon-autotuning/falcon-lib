struct Quantity {
    int a;
    int b = 0; // default value for b
    routine New (int a) -> (Quantity q) {
        Quantity q;
        q.a = a;
    }
    routine NewWithB (int a, int b) -> (Quantity q) {
        Quantity q;
        q.a = a;
        q.b = b;
    }
    routine Value  -> (int value) {
        value = a;
    }
    routine ValueWithB -> (int value) {
        value = a + b;
    }
}

autotuner QuantityStruct (int a, int b) -> (int sum, int other_sum) {
  sum = 0;
  other_sum = 0;
  
  start -> calculate;
  
  state calculate {
    Quantity q = New(a);
    sum = q.Value() + b;
    Quantity q_with_b = NewWithB(a, b);
    other_sum = q_with_b.ValueWithB();
    -> done;
  }
  
  state done {
    terminal;
  }
}
