autotuner StateRead -> (bool completed) {
  bool completed = false;

  start -> init;
  
  state init {
    // state reads should happen only to predefined variables
    int number = 0;
    Error nerr = nil;
    number, nerr = read(scope="globals", name="number", extra="default");
    if (number==0) {
        -> fail;
    }
    else {
        -> done;
    }
    -> done;
  }
  
  state done {
    completed = true;
    terminal;
  }
  state fail {
    log::info("We failed roger")
    terminal;
  }
}
