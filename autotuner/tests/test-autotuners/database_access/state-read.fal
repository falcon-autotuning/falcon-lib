import (
"io"
"log"
)
autotuner StateRead -> (bool completed) {
  completed = false;

  start -> init;
  
  state init {
    // state reads should happen only to predefined variables
    int number = 0;
    Error nerr = nil;
    number, nerr = io::readLatest(scope="globals", name="number", extra="default");
    if (number==0) {
        -> fail;
    }
    else {
        -> done;
    }
    -> done;
  }
  
  state done {
    completed = true;
    terminal;
  }
  state fail {
    log::Info("We failed roger");
    terminal;
  }
}
