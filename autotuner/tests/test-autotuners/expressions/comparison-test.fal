autotuner ComparisonTest (int a, int b) -> (bool gt, bool lt, bool eq, bool gte, bool lte) {
  bool gt = false;
  bool lt = false;
  bool eq = false;
  bool gte = false;
  bool lte = false;
  
  start -> compare;
  
  state compare {
    gt = a > b;
    lt = a < b;
    eq = a == b;
    gte = a >= b;
    lte = a <= b;
    -> done;
  }
  
  state done {
    terminal;
  }
}
