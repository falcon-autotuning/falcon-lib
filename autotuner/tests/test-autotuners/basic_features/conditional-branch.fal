autotuner ConditionalBranch (int threshold) -> (string result) {
  int value = 50;
  string result = "";
  
  start -> check;
  
  state check {
    if (value > threshold) {
      -> high;
    }
    else {
      -> low;
    }
  }
  
  state high {
    result = "high";
    -> done;
  }
  
  state low {
    result = "low";
    -> done;
  }
  
  state done {
    terminal;
  }
}
