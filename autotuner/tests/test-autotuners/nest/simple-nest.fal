autotuner ErrorViewer -> (bool completed) {
  requires : [DoNothing, FatalOtherError];

  bool outer_completed = false;
  bool inner_completed = false;
  
  start -> init;
  
  state init {
      outer_completed = DoNothing();
      -> done;
  }
  state done {
      Error err = nil;
      inner_completed, err = FatalOtherError();
      -> exit;
  }
  state exit {
      terminal;
  }
}
  
autotuner DoNothing -> (bool completed) {
  bool completed = true;
  
  start -> init;
  
  state init {
      terminal; 
  }
  
}
autotuner FatalOtherError() -> (bool completed, Error err) {
  bool completed = false;
  Error err = nil;
  
  start -> init;
  
  state init {
      err = FatalError::msg("We are really broken :(");
      terminal;
  }
  
}
