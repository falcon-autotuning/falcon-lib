autotuner ConditionalNest (int a, int b) -> (int out, Error err) {
  uses Adder, Multiplier;

  err = nil;
  out = 0;

  start -> init;
  
  state init {
      int add = 0;
      add, err = Adder(a, b);
      if (err != nil) {
        -> error_processing(err);
      }
      else {
        -> multiplication(add);
      }
  }
  state multiplication {
      int c =0;
      int multiplication = 0;
      multiplication, err = Multiplier(c, b);
      if (err != nil) {
          -> error_processing(err);
      }
      else {
          -> done(multiplication);
      }
  }
  state done (int out_inside) {
      out = out_inside;
      terminal;
  }
  state error_processing (Error error) {
      logInfo("We got an error with {}", error);
      terminal;
  }
}
autotuner Adder (int a , int b) -> (int add, Error err)  {
    add = 0;
    err = nil;
    start -> init;

    state init {
        add = a+ b;
        if (a < b) {
            err = errorMsg("Cannot add a less than b");
            terminal;
        }
        else {
            terminal;
        }
    }
}
autotuner Multiplier (int a , int b) -> (int mult, Error err)  {
    mult = 0;
    err = nil;
    start -> init;

    state init {
        if (a < b) {
            err = errorMsg("Cannot multiply a less than b");
            terminal;
        }
        else {
            mult = a* b;
            terminal;
        }
    }
}
