autotuner LogicalTest (bool flag1, bool flag2) -> (string result) {
  string result = "";
  
  start -> evaluate;
  
  state evaluate {
    if (flag1 == true) {
      if (flag2 == false) {
        result = "expected";
        -> done;
      }
      else {
        -> error_state;
      }
    }
    else {
      -> error_state;
    }
  }
  
  state done {
    terminal;
  }
  
  state error_state {
    result = "unexpected";
    terminal;
  }
}
