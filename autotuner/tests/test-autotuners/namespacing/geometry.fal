import "math_utils.fal";

routine area_square(float side) -> (float res) {
    res = side * side;
}

routine call_math_add(int x, int y) -> (int sum) {
    // Bare name fallback test
    sum = add(x, y);
}

routine call_math_add_scoped(int x, int y) -> (int sum) {
    // Scoped call test
    sum = math_utils::add(x, y);
}
