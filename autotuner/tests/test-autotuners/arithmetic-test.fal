autotuner ArithmeticTest (float x, float y) -> (float add, float sub, float mul, float div) {
  float add = 0.0;
  float sub = 0.0;
  float mul = 0.0;
  float div = 0.0;
  
  start -> calculate;
  
  state calculate {
    add = x + y;
    sub = x - y;
    mul = x * y;
    div = x / y;
    -> done;
  }
  
  state done {
    terminal;
  }
}
