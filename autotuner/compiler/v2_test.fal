autotuner VoltageSweep (float min_voltage) [plunger_gate] -> (float threshold) {
  spec-inputs: [
    Quantity pinchoff [plunger_gate]
  ]
  spec-outputs: [
    Quantity iv_curve_threshold [plunger_gate]
  ]
  params {
    float step_size = 0.01;
    int max_points = 100;
  }

  start -> init;

  for gate in config.plunger_gates {
    state sweep [gate] {
      temp { float v = 0.0; }
      run: run_sweep(gate, min_voltage);
      if (v > 1.0) -> finalize;
      else -> sweep[next gate];
    }
  }

  state init {
    -> check_ready;
  }

  state check_ready {
    if (ready) success;
    else fail "Device not ready";
  }

  state finalize {
    threshold = 0.5;
    terminal;
  }
}
