// ─────────────────────────────────────────────────────────────────────────────
// Suite 12: Database Delete Operations
// ─────────────────────────────────────────────────────────────────────────────
autotuner DeleteTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_delete_by_name_nonexistent (TestRunner runner, TestContext t) {
        string nonexistent = "delete_test_nonexistent_name_xyz123";
        bool deleted = database::DeleteByName(nonexistent);
        Error err = t.ExpectFalse(deleted, "DeleteByName returns false for nonexistent name");
        -> __end(runner, t);
    }

    state test_delete_by_hash_nonexistent (TestRunner runner, TestContext t) {
        string nonexistent_hash = "999";
        int deleted_count = database::DeleteByHash(nonexistent_hash);
        Error err = t.ExpectIntEq(deleted_count, 0, "DeleteByHash returns 0 for nonexistent hash");
        -> __end(runner, t);
    }

    state test_delete_by_name_created_characteristic (TestRunner runner, TestContext t) {
        // Create, insert, then delete
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("delete_me_001")
                     .SetExtra("delete_test_extra");
        database::Insert(dchar);
        
        // Verify it exists
        bool found = false;
        DeviceCharacteristic temp;
        temp, found = database::GetByName("delete_me_001");
        
        if (found) {
            bool deleted = database::DeleteByName("delete_me_001");
            Error err = t.ExpectTrue(deleted, "DeleteByName removes inserted characteristic");
        }
        
        Error err2 = t.ExpectTrue(true, "Delete test completed");
        -> __end(runner, t);
    }

    state test_delete_by_hash_created_characteristic (TestRunner runner, TestContext t) {
        // Create, insert, then delete by hash
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("delete_by_hash_001")
                     .SetHash("123")
                     .SetExtra("delete_hash_extra");
        database::Insert(dchar);
        
        // Delete by hash
        int deleted_count = database::DeleteByHash("123");
        Error err = t.ExpectIntGt(deleted_count, -1, "DeleteByHash returns count of deleted items");
        -> __end(runner, t);
    }
}

