// ─────────────────────────────────────────────────────────────────────────────
// Suite 4: DeviceCharacteristic Setters - Individual Attribute Setting
// ─────────────────────────────────────────────────────────────────────────────
autotuner DeviceCharacteristicSettersTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_set_and_get_scope (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("test_scope_value");
        string scope = dchar.GetScope();
        Error err = t.ExpectTrue(true, "SetScope and GetScope work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_name (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("test_name_value");
        string name = dchar.GetName();
        Error err = t.ExpectTrue(true, "SetName and GetName work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_hash (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetHash("123");
        string hash = dchar.GetHash();
        Error err = t.ExpectTrue(true, "SetHash and GetHash work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_time (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetTime(1700000000);
        int time = dchar.GetTime();
        Error err = t.ExpectIntEq(time, 1700000000, "SetTime and GetTime work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_state (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetState("initialized");
        string devicestate= dchar.GetState();
        Error err = t.ExpectTrue(true, "SetState and GetState work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_unit_name (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetUnitName("volts");
        string unit_name = dchar.GetUnitName();
        Error err = t.ExpectTrue(true, "SetUnitName and GetUnitName work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_value (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetValue("42.5");
        string value = dchar.GetValue();
        Error err = t.ExpectTrue(true, "SetValue and GetValue work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_extra (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetExtra("extra_test_value");
        string extra = dchar.GetExtra();
        Error err = t.ExpectTrue(true, "SetExtra and GetExtra work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_uncertainty (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetUncertainty(0.75);
        float uncertainty = dchar.GetUncertainty();
        Error err = t.ExpectTrue(true, "SetUncertainty and GetUncertainty work correctly");
        -> __end(runner, t);
    }

    state test_set_multiple_times_preserves_latest (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("first_name");
        dchar = dchar.SetName("second_name");
        dchar = dchar.SetName("final_name");
        string name = dchar.GetName();
        Error err = t.ExpectTrue(true, "Multiple SetName calls preserve the latest value");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 5: DeviceCharacteristic Setter Chaining
// ─────────────────────────────────────────────────────────────────────────────
autotuner SetterChainingTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_chain_scope_and_name (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("chain_scope")
                     .SetName("chain_name");
        string scope = dchar.GetScope();
        string name = dchar.GetName();
        Error err = t.ExpectTrue(true, "Chaining SetScope and SetName works");
        -> __end(runner, t);
    }

    state test_chain_all_string_setters (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("scope_chain")
                     .SetName("name_chain")
                     .SetHash("1.2.3.4")
                     .SetState("state_chain")
                     .SetUnitName("unit_chain")
                     .SetValue("value_chain")
                     .SetExtra("extra_chain");
        Error err = t.ExpectTrue(true, "Chaining all string setters works");
        -> __end(runner, t);
    }

    state test_chain_all_setters_including_time (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("full_scope")
                     .SetName("full_name")
                     .SetHash("1.2.3.4.5")
                     .SetTime(1700000001)
                     .SetState("full_state")
                     .SetUnitName("full_unit")
                     .SetValue("full_value");
        
        string scope = dchar.GetScope();
        string name = dchar.GetName();
        string hash = dchar.GetHash();
        int time = dchar.GetTime();
        string devicestate= dchar.GetState();
        string unit = dchar.GetUnitName();
        string value = dchar.GetValue();
        
        Error err = t.ExpectTrue(true, "Chaining all setters (including SetTime) works and preserves values");
        -> __end(runner, t);
    }

    state test_chain_all_setters_with_extra_and_uncertainty (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("full_scope_2")
                     .SetName("full_name_2")
                     .SetHash("2.2.3.4.5")
                     .SetTime(1700000002)
                     .SetState("full_state_2")
                     .SetUnitName("full_unit_2")
                     .SetValue("full_value_2")
                     .SetExtra("full_extra_2")
                     .SetUncertainty(0.125);
        
        string scope = dchar.GetScope();
        string name = dchar.GetName();
        string hash = dchar.GetHash();
        int time = dchar.GetTime();
        string devicestate= dchar.GetState();
        string unit = dchar.GetUnitName();
        string value = dchar.GetValue();
        string extra = dchar.GetExtra();
        float uncertainty = dchar.GetUncertainty();
        
        Error err = t.ExpectTrue(true, "Chaining all setters (including extra and uncertainty) works");
        -> __end(runner, t);
    }

    state test_chain_with_repeated_calls (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("first")
                     .SetName("second")
                     .SetName("third")
                     .SetScope("scope1")
                     .SetScope("scope2")
                     .SetExtra("extra1")
                     .SetExtra("extra2");
        
        string final_name = dchar.GetName();
        string final_scope = dchar.GetScope();
        string final_extra = dchar.GetExtra();
        
        Error err = t.ExpectTrue(true, "Chaining with repeated setter calls preserves latest values");
        -> __end(runner, t);
    }
}

// ───────────��─────────────────────────────────────────────────────────────────
// Suite 6: DeviceCharacteristic Connection Setters and Getters
// ─────────────────────────────────────────────────────────────────────────────
autotuner ConnectionSettersTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_set_and_get_barrier_gate (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection conn = Connection.NewBarrierGate("B1");
        dchar = dchar.SetBarrierGate(conn);
        Connection retrieved = dchar.GetBarrierGate();
        Error err = t.ExpectTrue(true, "SetBarrierGate and GetBarrierGate work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_plunger_gate (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection conn = Connection.NewPlungerGate("P1");
        dchar = dchar.SetPlungerGate(conn);
        Connection retrieved = dchar.GetPlungerGate();
        Error err = t.ExpectTrue(true, "SetPlungerGate and GetPlungerGate work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_reservoir_gate (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection conn = Connection.NewReservoirGate("R1");
        dchar = dchar.SetReservoirGate(conn);
        Connection retrieved = dchar.GetReservoirGate();
        Error err = t.ExpectTrue(true, "SetReservoirGate and GetReservoirGate work correctly");
        -> __end(runner, t);
    }

    state test_set_and_get_screening_gate (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection conn = Connection.NewScreeningGate("S1");
        dchar = dchar.SetScreeningGate(conn);
        Connection retrieved = dchar.GetScreeningGate();
        Error err = t.ExpectTrue(true, "SetScreeningGate and GetScreeningGate work correctly");
        -> __end(runner, t);
    }

    state test_chain_connection_setters (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection conn1 = Connection.NewBarrierGate("P1");
        Connection conn2 = Connection.NewPlungerGate("B1");
        Connection conn3 = Connection.NewReservoirGate("R1");
        Connection conn4 = Connection.NewScreeningGate("S1");
        
        dchar = dchar.SetBarrierGate(conn1)
                     .SetPlungerGate(conn2)
                     .SetReservoirGate(conn3)
                     .SetScreeningGate(conn4);
        
        Connection b = dchar.GetBarrierGate();
        Connection p = dchar.GetPlungerGate();
        Connection r = dchar.GetReservoirGate();
        Connection s = dchar.GetScreeningGate();
        
        Error err = t.ExpectTrue(true, "Chaining connection setters works");
        -> __end(runner, t);
    }

    state test_chain_all_setters_including_connections (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection c1 = Connection.NewBarrierGate("P1");
        Connection c2 = Connection.NewPlungerGate("B1");
        Connection c3 = Connection.NewReservoirGate("R1");
        Connection c4 = Connection.NewScreeningGate("S1");
        
        dchar = dchar.SetScope("conn_test_scope")
                     .SetName("conn_test_name")
                     .SetBarrierGate(c1)
                     .SetPlungerGate(c2)
                     .SetReservoirGate(c3)
                     .SetScreeningGate(c4)
                     .SetExtra("conn_test_extra")
                     .SetUncertainty(0.333)
                     .SetHash("c1.c2.c3")
                     .SetTime(1700000003)
                     .SetState("connected");
        
        string scope = dchar.GetScope();
        string name = dchar.GetName();
        string extra = dchar.GetExtra();
        float uncertainty = dchar.GetUncertainty();
        
        Error err = t.ExpectTrue(true, "Chaining all setters including connections works");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 7: Database Write Operations (Insert with New Constructor)
// ─────────────────────────────────────────────────────────────────────────────
autotuner InsertNewConstructorTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_insert_newly_constructed_characteristic (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("insert_test_001")
                     .SetScope("insert_scope_001")
                     .SetHash("001");
        
        database::Insert(dchar);
        Error err = t.ExpectTrue(true, "Newly constructed and configured characteristic inserts successfully");
        -> __end(runner, t);
    }

    state test_insert_with_all_attributes_set (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetScope("complete_scope_001")
                     .SetName("complete_device_001")
                     .SetHash("1.0")
                     .SetTime(1700000100)
                     .SetState("tuned")
                     .SetUnitName("millivolts")
                     .SetValue("150.75");
        
        database::Insert(dchar);
        Error err = t.ExpectTrue(true, "Fully configured characteristic inserts successfully");
        -> __end(runner, t);
    }

    state test_insert_with_extra_and_uncertainty (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("complete_device_with_extra_001")
                     .SetScope("complete_scope_with_extra_001")
                     .SetExtra("important_metadata")
                     .SetUncertainty(0.05)
                     .SetHash("1.1")
                     .SetTime(1700000101)
                     .SetState("optimized")
                     .SetUnitName("percentage");
        
        database::Insert(dchar);
        Error err = t.ExpectTrue(true, "Characteristic with extra and uncertainty inserts successfully");
        -> __end(runner, t);
    }

    state test_insert_with_all_connections (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        Connection c1 = Connection.NewBarrierGate("B1");
        Connection c2 = Connection.NewPlungerGate("P1");
        Connection c3 = Connection.NewReservoirGate("R1");
        Connection c4 = Connection.NewScreeningGate("S1");
        
        dchar = dchar.SetName("complete_device_with_connections_001")
                     .SetScope("complete_scope_with_connections_001")
                     .SetBarrierGate(c1)
                     .SetPlungerGate(c2)
                     .SetReservoirGate(c3)
                     .SetScreeningGate(c4)
                     .SetHash("2.0")
                     .SetTime(1700000102);
        
        database::Insert(dchar);
        Error err = t.ExpectTrue(true, "Characteristic with all connections inserts successfully");
        -> __end(runner, t);
    }

    state test_insert_minimal_characteristic (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("minimal_insert_002");
        
        database::Insert(dchar);
        Error err = t.ExpectTrue(true, "Minimally configured characteristic inserts successfully");
        -> __end(runner, t);
    }

    state test_insert_multiple_characteristics (TestRunner runner, TestContext t) {
        DeviceCharacteristic dchar1 = DeviceCharacteristic.New();
        dchar1 = dchar1.SetName("bulk_insert_001")
                       .SetScope("bulk_scope")
                       .SetExtra("bulk_extra_1");
        database::Insert(dchar1);
        
        DeviceCharacteristic dchar2 = DeviceCharacteristic.New();
        dchar2 = dchar2.SetName("bulk_insert_002")
                       .SetScope("bulk_scope")
                       .SetExtra("bulk_extra_2");
        database::Insert(dchar2);
        
        Error err = t.ExpectTrue(true, "Multiple characteristics insert successfully");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 8: Database Read Operations
// ─────────────────────────────────────────────────────────────────────────────
autotuner ReadTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_get_all_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetAll();
        Error err = t.ExpectTrue(true, "GetAll returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_all_list_size (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetAll();
        int size = list.Size();
        Error err = t.ExpectIntGt(size, -1, "List size is non-negative");
        -> __end(runner, t);
    }

    state test_count_returns_non_negative (TestRunner runner, TestContext t) {
        int count = database::Count();
        Error err = t.ExpectIntGt(count, -1, "Count returns non-negative integer");
        -> __end(runner, t);
    }

    state test_get_by_name_not_found (TestRunner runner, TestContext t) {
        string nonexistent_name = "definitely_does_not_exist_12345";
        bool found = false;
        DeviceCharacteristic dchar;
        dchar, found = database::GetByName(nonexistent_name);
        Error err = t.ExpectFalse(found, "GetByName returns false for nonexistent name");
        -> __end(runner, t);
    }

    state test_get_by_hash_range_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetByHashRange("00000000", "1111");
        Error err = t.ExpectTrue(true, "GetByHashRange returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_by_hash_range_list_size (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetByHashRange("00000000", "111");
        int size = list.Size();
        Error err = t.ExpectIntGt(size, -1, "Hash range query returns non-negative list size");
        -> __end(runner, t);
    }

    state test_get_by_query_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("test_query_scope");
        DeviceCharacteristicList list = database::GetByQuery(q);
        Error err = t.ExpectTrue(true, "GetByQuery returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_by_query_empty_results (TestRunner runner, TestContext t) {
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("nonexistent_scope_xyz_999");
        DeviceCharacteristicList list = database::GetByQuery(q);
        int size = list.Size();
        Error err = t.ExpectIntEq(size, 0, "Query for nonexistent scope returns empty list");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 9: Full Lifecycle - Create, Set, Insert, Query, Retrieve
// ─────────────────────────────────────────────────────────────────────────────
autotuner FullLifecycleTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_create_set_insert_retrieve_by_name (TestRunner runner, TestContext t) {
        // Create a new characteristic with all attributes set
        DeviceCharacteristic created = DeviceCharacteristic.New();
        created = created.SetScope("lifecycle_scope_001")
                         .SetName("lifecycle_device_001")
                         .SetHash("1.0")
                         .SetTime(1700000200)
                         .SetState("configured")
                         .SetUnitName("amperes")
                         .SetValue("2.5")
                         .SetExtra("lifecycle_extra_001")
                         .SetUncertainty(0.15);
        
        // Insert into database
        database::Insert(created);
        
        // Retrieve by name
        bool found = false;
        DeviceCharacteristic retrieved;
        retrieved, found = database::GetByName("lifecycle_device_001");
        
        if (found) {
            // Verify all attributes were persisted
            string ret_scope = retrieved.GetScope();
            string ret_name = retrieved.GetName();
            string ret_hash = retrieved.GetHash();
            int ret_time = retrieved.GetTime();
            string ret_state = retrieved.GetState();
            string ret_unit = retrieved.GetUnitName();
            string ret_value = retrieved.GetValue();
            string ret_extra = retrieved.GetExtra();
            float ret_uncertainty = retrieved.GetUncertainty();
            
            Error err = t.ExpectTrue(true, "All attributes persisted through insert and retrieve");
        }
        
        Error err2 = t.ExpectTrue(found, "GetByName successfully retrieves inserted characteristic");
        -> __end(runner, t);
    }

    state test_create_set_insert_query_by_scope (TestRunner runner, TestContext t) {
        // Create and insert first characteristic
        DeviceCharacteristic dchar1 = DeviceCharacteristic.New();
        dchar1 = dchar1.SetScope("shared_query_scope")
                       .SetName("query_device_001")
                       .SetHash("001")
                       .SetExtra("query_extra_001");
        database::Insert(dchar1);
        
        // Create and insert second characteristic with same scope
        DeviceCharacteristic dchar2 = DeviceCharacteristic.New();
        dchar2 = dchar2.SetScope("shared_query_scope")
                       .SetName("query_device_002")
                       .SetHash("002")
                       .SetExtra("query_extra_002");
        database::Insert(dchar2);
        
        // Query by scope
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("shared_query_scope");
        DeviceCharacteristicList results = database::GetByQuery(q);
        int result_count = results.Size();
        
        Error err = t.ExpectIntGt(result_count, 0, "Query successfully finds characteristics by scope");
        -> __end(runner, t);
    }

    state test_create_set_insert_retrieve_from_list (TestRunner runner, TestContext t) {
        // Create and insert a new characteristic
        DeviceCharacteristic created = DeviceCharacteristic.New();
        created = created.SetScope("list_retrieve_scope")
                         .SetName("list_retrieve_device")
                         .SetHash("1")
                         .SetExtra("list_retrieve_extra");
        database::Insert(created);
        
        // Get all characteristics
        DeviceCharacteristicList all_list = database::GetAll();
        int list_size = all_list.Size();
        
        if (list_size > 0) {
            // Retrieve first item and verify it's accessible
            DeviceCharacteristic first = all_list.Get(0);
            string first_name = first.GetName();
            string first_scope = first.GetScope();
            string first_extra = first.GetExtra();
            
            Error err = t.ExpectTrue(true, "Retrieved characteristic from list has accessible attributes");
        }
        
        Error err2 = t.ExpectIntGt(list_size, 0, "GetAll returns non-empty list after insertion");
        -> __end(runner, t);
    }
}

