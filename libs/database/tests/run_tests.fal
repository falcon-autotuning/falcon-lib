// ─────────────────────────────────────────────────────────────────────────────
// Suite 14: Database Snapshot Operations (Export/Import)
// ─────────────────────────────────────────────────────────────────────────────
autotuner SnapshotTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_export_to_json (TestRunner runner, TestContext t) {
        string test_file = "/tmp/falcon_test_export.json";
        database::ExportToJson(test_file);
        Error err = t.ExpectTrue(true, "ExportToJson completes without error");
        -> __end(runner, t);
    }

    state test_import_from_json_without_clear (TestRunner runner, TestContext t) {
        string test_file = "/tmp/falcon_test_export.json";
        database::ExportToJson(test_file);
        database::ImportFromJson(test_file, false);
        Error err = t.ExpectTrue(true, "ImportFromJson (without clear) completes without error");
        -> __end(runner, t);
    }

    state test_import_from_json_with_clear (TestRunner runner, TestContext t) {
        string test_file = "/tmp/falcon_test_import_clear.json";
        database::ExportToJson(test_file);
        
        Error err = t.Log("ImportFromJson with clear_existing=true is destructive");
        err = t.ExpectTrue(true, "ImportFromJson with clear flag would reset database");
        -> __end(runner, t);
    }

    state test_export_then_count_unchanged (TestRunner runner, TestContext t) {
        int count_before = database::Count();
        string test_file = "/tmp/falcon_test_count.json";
        database::ExportToJson(test_file);
        int count_after = database::Count();
        Error err = t.ExpectIntEq(count_before, count_after, "ExportToJson does not modify database");
        -> __end(runner, t);
    }
}

// ────────────────���────────────────────────────────────────────────────────────
// Suite 15: Integration Tests - End-to-End Workflows
// ─────────────────────────────────────────────────────────────────────────────
autotuner IntegrationTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_connection_then_count (TestRunner runner, TestContext t) {
        int count = database::Count();
        Error err = t.ExpectIntGt(count, -1, "Count returns valid result after connection");
        -> __end(runner, t);
    }

    state test_multiple_database_instances (TestRunner runner, TestContext t) {
        
        int count1 = database::Count();
        int count2 = database::Count();
        
        Error err = t.ExpectIntEq(count1, count2, "Multiple Database instances see same data");
        -> __end(runner, t);
    }

    state test_query_builder_with_getbyquery (TestRunner runner, TestContext t) {
        
        // Get a reference entry first
        DeviceCharacteristicList all_list = database::GetAll();
        int all_size = all_list.Size();
        
        if (all_size > 0) {
            DeviceCharacteristic ref = all_list.Get(0);
            string ref_scope = ref.GetScope();
            
            // Now query by that scope
            DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
            q = q.SetScope(ref_scope);
            DeviceCharacteristicList query_list = database::GetByQuery(q);
            int query_size = query_list.Size();
            
            Error err = t.ExpectIntGt(query_size, 0, "Query by existing scope returns results");
        }
        
        Error err = t.ExpectTrue(true, "Query builder integration test completed");
        -> __end(runner, t);
    }

    state test_export_import_roundtrip (TestRunner runner, TestContext t) {
        int count_original = database::Count();
        
        string export_file = "/tmp/falcon_test_roundtrip.json";
        database::ExportToJson(export_file);
        
        // Import without clearing - should not change count significantly
        database::ImportFromJson(export_file, false);
        int count_after_import = database::Count();
        
        Error err = t.ExpectIntGt(count_after_import, count_original - 1, "Import maintains database integrity");
        -> __end(runner, t);
    }

    state test_complete_workflow_create_insert_query_delete (TestRunner runner, TestContext t) {
        // Create multiple characteristics with extra and uncertainty
        DeviceCharacteristic wf_char1 = DeviceCharacteristic.New();
        wf_char1 = wf_char1.SetScope("workflow_scope")
                            .SetName("workflow_device_1")
                            .SetHash("1")
                            .SetState("active")
                            .SetExtra("workflow_extra_1")
                            .SetUncertainty(0.1);
        database::Insert(wf_char1);
        
        DeviceCharacteristic wf_char2 = DeviceCharacteristic.New();
        wf_char2 = wf_char2.SetScope("workflow_scope")
                            .SetName("workflow_device_2")
                            .SetHash("2")
                            .SetState("active")
                            .SetExtra("workflow_extra_2")
                            .SetUncertainty(0.2);
        database::Insert(wf_char2);
        
        // Query by scope
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("workflow_scope");
        DeviceCharacteristicList results = database::GetByQuery(q);
        int result_count = results.Size();
        
        // Retrieve and modify each result
        if (result_count > 0) {
            DeviceCharacteristic first = results.Get(0);
            string first_name = first.GetName();
            string first_extra = first.GetExtra();
            float first_uncertainty = first.GetUncertainty();
            
            // Try to delete one
            bool deleted = database::DeleteByName("workflow_device_1");
            
            Error err = t.ExpectTrue(deleted, "Workflow: created, inserted, queried, and deleted successfully");
        }
        
        Error err2 = t.ExpectTrue(true, "Complete workflow test finished");
        -> __end(runner, t);
    }

    state test_query_with_extra_and_uncertainty_filters (TestRunner runner, TestContext t) {
        // Create characteristics with various extra and uncertainty values
        DeviceCharacteristic dchar1 = DeviceCharacteristic.New();
        dchar1 = dchar1.SetName("filter_test_001")
                       .SetScope("filter_scope")
                       .SetExtra("important")
                       .SetUncertainty(0.05);
        database::Insert(dchar1);
        
        DeviceCharacteristic dchar2 = DeviceCharacteristic.New();
        dchar2 = dchar2.SetName("filter_test_002")
                       .SetScope("filter_scope")
                       .SetExtra("standard")
                       .SetUncertainty(0.15);
        database::Insert(dchar2);
        
        // Query with extra filter
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("filter_scope")
             .SetExtra("important");
        DeviceCharacteristicList results = database::GetByQuery(q);
        int result_count = results.Size();
        
        Error err = t.ExpectIntGt(result_count, -1, "Query with extra filter returns results");
        -> __end(runner, t);
    }

    state test_connections_in_full_workflow (TestRunner runner, TestContext t) {
        Connection c1 = Connection.NewBarrierGate("B1");
        Connection c2 = Connection.NewPlungerGate("P1");
        
        // Create characteristic with connections
        DeviceCharacteristic dchar = DeviceCharacteristic.New();
        dchar = dchar.SetName("conn_workflow_001")
                     .SetScope("conn_workflow_scope")
                     .SetBarrierGate(c1)
                     .SetPlungerGate(c2)
                     .SetExtra("connection_test")
                     .SetUncertainty(0.08);
        database::Insert(dchar);
        
        // Retrieve and verify all attributes
        bool found = false;
        DeviceCharacteristic retrieved;
        retrieved, found = database::GetByName("conn_workflow_001");
        
        if (found) {
            Connection retrieved_barrier = retrieved.GetBarrierGate();
            Connection retrieved_plunger = retrieved.GetPlungerGate();
            string retrieved_extra = retrieved.GetExtra();
            float retrieved_uncertainty = retrieved.GetUncertainty();
            
            Error err = t.ExpectTrue(true, "Full workflow with connections completed successfully");
        }
        
        Error err2 = t.ExpectTrue(found, "Characteristic with connections retrieved successfully");
        -> __end(runner, t);
    }
}
