// ─────────────────────────────────────────────────────────────────────────────
// Suite 4: Database Read Operations
// ─────────────────────────────────────────────────────────────────────────────
autotuner ReadTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_get_all_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetAll();
        Error err = t.ExpectTrue(true, "GetAll returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_all_list_size (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetAll();
        int size = list.Size();
        Error err = t.ExpectIntGt(size, -1, "List size is non-negative");
        -> __end(runner, t);
    }

    state test_count_returns_non_negative (TestRunner runner, TestContext t) {
        int count = database::Count();
        Error err = t.ExpectIntGt(count, -1, "Count returns non-negative integer");
        -> __end(runner, t);
    }

    state test_get_by_name_not_found (TestRunner runner, TestContext t) {
        string nonexistent_name = "definitely_does_not_exist_12345";
        bool found = false;
        DeviceCharacteristic dchar;
        dchar, found = database::GetByName(nonexistent_name);
        Error err = t.ExpectFalse(found, "GetByName returns false for nonexistent name");
        -> __end(runner, t);
    }

    state test_get_by_hash_range_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetByHashRange("00000000", "ffffffff");
        Error err = t.ExpectTrue(true, "GetByHashRange returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_by_hash_range_list_size (TestRunner runner, TestContext t) {
        DeviceCharacteristicList list = database::GetByHashRange("00000000", "ffffffff");
        int size = list.Size();
        Error err = t.ExpectIntGt(size, -1, "Hash range query returns non-negative list size");
        -> __end(runner, t);
    }

    state test_get_by_query_returns_list (TestRunner runner, TestContext t) {
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("test_query_scope");
        DeviceCharacteristicList list = database::GetByQuery(q);
        Error err = t.ExpectTrue(true, "GetByQuery returns DeviceCharacteristicList");
        -> __end(runner, t);
    }

    state test_get_by_query_empty_results (TestRunner runner, TestContext t) {
        DeviceCharacteristicQuery q = DeviceCharacteristicQuery.New();
        q = q.SetScope("nonexistent_scope_xyz_999");
        DeviceCharacteristicList list = database::GetByQuery(q);
        int size = list.Size();
        Error err = t.ExpectIntEq(size, 0, "Query for nonexistent scope returns empty list");
        -> __end(runner, t);
    }
}

