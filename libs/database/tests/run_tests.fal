        DeviceCharacteristicList list = database::GetAll();
        int size = list.Size();
        
        if (size > 0) {
            DeviceCharacteristic dchar = list.Get(0);
            string json_str = dchar.ToJson();
            bool has_brace = Contains(json_str, "{");
            Error err = t.ExpectTrue(has_brace, "ToJson returns valid JSON string with opening brace");
