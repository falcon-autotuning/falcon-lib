ffimport "log-wrapper.cpp" ("/opt/falcon/include/spdlog/") ("/opt/falcon/lib/libspdlog.so")

struct Log {
    routine New() -> (Log logger)
    routine Info(string message) -> (Error err)
    routine Debug(string message) -> (Error err)
    routine Warn(string message) -> (Error err)
    routine Error(string message) -> (Error err)
}
