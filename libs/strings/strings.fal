import "github.com/falcon-autotuning/falcon-lib/libs/collections/array/array.fal";
ffimport "strings-wrapper.cpp" ("-I/opt/falcon/include/") ("-L/opt/falcon/lib/" "-lfmt")

// ── Predicates ────────────────────────────────────────────────────────────────

// Returns true if `s` contains the substring `sub`.
routine Contains    (string s, string sub)              -> (bool found)

// Returns true if `s` starts with `prefix`.
routine StartsWith  (string s, string prefix)           -> (bool found)

// Returns true if `s` ends with `suffix`.
routine EndsWith    (string s, string suffix)           -> (bool found)

// Returns the number of bytes in `s`.
routine Length      (string s)                          -> (int len)

// Returns true if `s` is the empty string.
routine IsEmpty     (string s)                          -> (bool empty)

// ── Transformations ───────────────────────────────────────────────────────────

// Convert `s` to upper-case ASCII.
routine ToUpper     (string s)                          -> (string result)

// Convert `s` to lower-case ASCII.
routine ToLower     (string s)                          -> (string result)

// Strip leading and trailing whitespace (space, tab, CR, LF, FF, VT).
routine TrimSpace   (string s)                          -> (string result)

// Replace the first occurrence of `from` with `to` in `s`.
routine Replace     (string s, string from, string to)  -> (string result)

// Replace every occurrence of `from` with `to` in `s`.
routine ReplaceAll  (string s, string from, string to)  -> (string result)

// Concatenate two strings.
routine Concat      (string a, string b)                -> (string result)

// Extract a sub-string starting at byte offset `start` of length `length`.
routine Substring   (string s, int begin, int length)   -> (string result)

// Return the byte offset of the first occurrence of `sub` in `s`, or -1.
routine IndexOf     (string s, string sub)              -> (int index)

// Remove all ANSI / VT100 escape sequences from `s` (e.g. colour codes).
routine StripAnsi   (string s)                          -> (string result)

// ── Conversion ────────────────────────────────────────────────────────────────

// Convert an integer to its string representation.
routine FromInt     (int i)                             -> (string result)

// Convert a double to its string representation.
routine FromDouble  (float f)                           -> (string result)

// Convert a boolean to "true" or "false".
routine FromBool    (bool b)                            -> (string result)

// Parse an integer from its string representation.
routine ToInt       (string s)                          -> (int result)

// Parse a double from its string representation.
routine ToDouble    (string s)                          -> (float result)

// Parse a boolean from "true"/"1" or "false"/"0".
routine ToBool      (string s)                          -> (bool result)

// ── Regex ─────────────────────────────────────────────────────────────────────

// RegexMatch — holds the result of a single regex search.
struct RegexMatch {
    // Run `pattern` against `text`; returns a match object.
    routine New        (string pattern, string text)    -> (RegexMatch m)

    // True if the pattern matched anywhere in the text.
    routine Matched                                     -> (bool matched)

    // The full matched substring (group 0).
    routine Full                                        -> (string full_match)

    // Capture group n (1-based).  Returns "" if n is out of range.
    routine Group      (int n)                          -> (string group)

    // Number of capture groups (not counting group 0).
    routine GroupCount                                  -> (int count)
}

// Quick boolean test — returns true if `pattern` matches anywhere in `text`.
routine RegexTest    (string pattern, string text)      -> (bool matched)

// Replace all matches of `pattern` in `s` with `replacement`.
// Standard ECMAScript/POSIX regex syntax; `$1`, `$2` back-references are supported.
routine RegexReplace (string s, string pattern, string replacement) -> (string result)

// Format a string using {}-substitution for each argument in the array.
// Example: Format("Hello, {}!", ["world"]) -> "Hello, world!"
routine Format(string fmt, Array<string> args) -> (string result)
