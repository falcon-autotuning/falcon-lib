autotuner SymbolUnitEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_unit (TestRunner runner, TestContext t) {
        SymbolUnit a = SymbolUnit.Volt();
        SymbolUnit b = SymbolUnit.Volt();
        Error err = t.ExpectTrue(a.IsEqual(b), "Volt == Volt");
        -> __end(runner, t);
    }

    state test_not_equal_different_units (TestRunner runner, TestContext t) {
        SymbolUnit a = SymbolUnit.Volt();
        SymbolUnit b = SymbolUnit.Ampere();
        Error err = t.ExpectTrue(a.IsNotEqual(b), "Volt != Ampere");
        -> __end(runner, t);
    }

    state test_is_equal_false_for_different (TestRunner runner, TestContext t) {
        SymbolUnit a = SymbolUnit.Hertz();
        SymbolUnit b = SymbolUnit.Second();
        Error err = t.ExpectFalse(a.IsEqual(b), "Hertz != Second");
        -> __end(runner, t);
    }

    state test_is_not_equal_false_for_same (TestRunner runner, TestContext t) {
        SymbolUnit a = SymbolUnit.Kilogram();
        SymbolUnit b = SymbolUnit.Kilogram();
        Error err = t.ExpectFalse(a.IsNotEqual(b), "Kilogram == Kilogram so IsNotEqual is false");
        -> __end(runner, t);
    }
}

autotuner SymbolUnitJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_roundtrip_volt (TestRunner runner, TestContext t) {
        SymbolUnit orig = SymbolUnit.Volt();
        string json     = orig.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON returns non-empty string");
        SymbolUnit restored = SymbolUnit.FromJSON(json);
        err = t.ExpectTrue(orig.IsEqual(restored), "FromJSON(ToJSON(Volt)) == Volt");
        -> __end(runner, t);
    }

    state test_roundtrip_milliampere (TestRunner runner, TestContext t) {
        SymbolUnit orig = SymbolUnit.Milliampere();
        string json     = orig.ToJSON();
        SymbolUnit restored = SymbolUnit.FromJSON(json);
        Error err = t.ExpectTrue(orig.IsEqual(restored), "mA round-trip");
        -> __end(runner, t);
    }
}
