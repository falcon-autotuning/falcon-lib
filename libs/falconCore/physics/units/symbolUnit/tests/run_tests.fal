// Tests for falcon_core/physics/units/symbolUnit
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../symbolUnit.fal";

autotuner SymbolUnitConstructors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_meter (TestRunner runner, TestContext t) {
        SymbolUnit u = SymbolUnit.Meter();
        Error err = t.ExpectStrEq("m", u.Symbol(), "Meter symbol is m");
        err = t.ExpectStrEq("meter", u.Name(), "Meter name is meter");
        -> __end(runner, t);
    }

    state test_kilogram (TestRunner runner, TestContext t) {
        SymbolUnit u = SymbolUnit.Kilogram();
