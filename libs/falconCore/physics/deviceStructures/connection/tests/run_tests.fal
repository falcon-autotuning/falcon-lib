// Tests for falcon_core/physics/deviceStructures/connection
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../connection.fal";

autotuner ConnectionConstructors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_plunger_gate_name (TestRunner runner, TestContext t) {
        Connection c = Connection.NewPlungerGate("P1");
        Error err = t.ExpectStrEq("P1", c.Name(), "PlungerGate name is P1");
        -> __end(runner, t);
    }

    state test_barrier_gate_name (TestRunner runner, TestContext t) {
        Connection c = Connection.NewBarrierGate("B1");
        Error err = t.ExpectStrEq("B1", c.Name(), "BarrierGate name is B1");
        -> __end(runner, t);
    }

    state test_reservoir_gate_name (TestRunner runner, TestContext t) {
        Connection c = Connection.NewReservoirGate("R1");
        Error err = t.ExpectStrEq("R1", c.Name(), "ReservoirGate name is R1");
        -> __end(runner, t);
    }

    state test_screening_gate_name (TestRunner runner, TestContext t) {
        Connection c = Connection.NewScreeningGate("SC1");
        Error err = t.ExpectStrEq("SC1", c.Name(), "ScreeningGate name is SC1");
        -> __end(runner, t);
    }

    state test_ohmic_name (TestRunner runner, TestContext t) {
        Connection c = Connection.NewOhmic("S1");
        Error err = t.ExpectStrEq("S1", c.Name(), "Ohmic name is S1");
        -> __end(runner, t);
    }
}

