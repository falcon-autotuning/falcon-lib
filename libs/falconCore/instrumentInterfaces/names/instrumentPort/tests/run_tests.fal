autotuner InstrumentPortEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort a      = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        InstrumentPort b      = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        Error err = t.ExpectTrue(a.Equal(b), "Same knob ports are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_name (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        Connection p2         = Connection.NewPlungerGate("P2");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort a      = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        InstrumentPort b      = InstrumentPort.NewKnob("P2", p2, dc, volt, "plunger");
        Error err = t.ExpectTrue(a.NotEqual(b), "Different names are not equal");
        -> __end(runner, t);
    }

    state test_knob_not_equal_meter (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort knob   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        InstrumentPort meter  = InstrumentPort.NewMeter("P1", p1, dc, volt, "plunger");
        Error err = t.ExpectTrue(knob.NotEqual(meter), "Knob and meter are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        Connection b1         = Connection.NewBarrierGate("B1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort a      = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        InstrumentPort b      = InstrumentPort.NewKnob("B1", b1, dc, volt, "barrier");
        Error err = t.ExpectFalse(a.Equal(b), "Equal is false for different ports");
        -> __end(runner, t);
    }
}

autotuner InstrumentPortJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        string json = port.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort orig   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        string json           = orig.ToJSON();
        InstrumentPort res    = InstrumentPort.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(res), "ToJSON/FromJSON round-trips");
        -> __end(runner, t);
    }

    state test_from_json_default_name (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort orig   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger");
        string json           = orig.ToJSON();
        InstrumentPort res    = InstrumentPort.FromJSON(json);
        Error err = t.ExpectStrEq("P1", res.DefaultName(), "FromJSON preserves default name");
        -> __end(runner, t);
    }
}
