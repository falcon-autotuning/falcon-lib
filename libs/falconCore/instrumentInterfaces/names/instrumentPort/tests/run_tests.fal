// Tests for falconCore/instrumentInterfaces/names/instrumentPort
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../instrumentPort.fal";
import "../../../../physics/deviceStructures/connection/connection.fal";
import "../../../../physics/units/symbolUnit/symbolUnit.fal";
import "../../instrument/instrument.fal";

autotuner InstrumentPortKnobConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_knob_default_name (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        Error err = t.ExpectStrEq("P1", port.DefaultName(), "Knob default name is P1");
        -> __end(runner, t);
    }

    state test_knob_is_knob (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        Error err = t.ExpectTrue(port.IsKnob(), "NewKnob port is a knob");
        -> __end(runner, t);
    }

    state test_knob_is_not_meter (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        Error err = t.ExpectFalse(port.IsMeter(), "NewKnob port is not a meter");
        -> __end(runner, t);
    }

    state test_knob_pseudo_name (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        Connection got        = port.PsuedoName();
        Error err = t.ExpectStrEq("P1", got.Name(), "Knob pseudo-name connection is P1");
        -> __end(runner, t);
    }

    state test_knob_units (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        SymbolUnit u          = port.Units();
        Error err = t.ExpectStrEq("V", u.Symbol(), "Knob unit symbol is V");
        -> __end(runner, t);
    }

    state test_knob_description (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        Error err = t.ExpectStrEq("plunger gate", port.Description(), "Knob description matches");
        -> __end(runner, t);
    }

    state test_knob_instrument_type (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        string dc             = Instrument.DCVoltageSource();
        InstrumentPort port   = InstrumentPort.NewKnob("P1", p1, dc, volt, "plunger gate");
        string itype          = port.InstrumentType();
        Error err = t.ExpectStrNe("", itype, "Knob instrument type is non-empty");
        -> __end(runner, t);
    }
}

autotuner InstrumentPortMeterConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_meter_default_name (TestRunner runner, TestContext t) {
        Connection i1         = Connection.NewOhmic("I1");
        SymbolUnit amp        = SymbolUnit.Ampere();
        string amm            = Instrument.Amnmeter();
        InstrumentPort port   = InstrumentPort.NewMeter("I1", i1, amm, amp, "current meter");
        Error err = t.ExpectStrEq("I1", port.DefaultName(), "Meter default name is I1");
        -> __end(runner, t);
    }

    state test_meter_is_meter (TestRunner runner, TestContext t) {
        Connection i1         = Connection.NewOhmic("I1");
        SymbolUnit amp        = SymbolUnit.Ampere();
        string amm            = Instrument.Amnmeter();
        InstrumentPort port   = InstrumentPort.NewMeter("I1", i1, amm, amp, "current meter");
        Error err = t.ExpectTrue(port.IsMeter(), "NewMeter port is a meter");
        -> __end(runner, t);
    }

    state test_meter_is_not_knob (TestRunner runner, TestContext t) {
        Connection i1         = Connection.NewOhmic("I1");
        SymbolUnit amp        = SymbolUnit.Ampere();
        string amm            = Instrument.Amnmeter();
        InstrumentPort port   = InstrumentPort.NewMeter("I1", i1, amm, amp, "current meter");
        Error err = t.ExpectFalse(port.IsKnob(), "NewMeter port is not a knob");
        -> __end(runner, t);
    }

    state test_meter_units (TestRunner runner, TestContext t) {
        Connection i1         = Connection.NewOhmic("I1");
        SymbolUnit amp        = SymbolUnit.Ampere();
        string amm            = Instrument.Amnmeter();
        InstrumentPort port   = InstrumentPort.NewMeter("I1", i1, amm, amp, "current meter");
        SymbolUnit u          = port.Units();
        Error err = t.ExpectStrEq("A", u.Symbol(), "Meter unit symbol is A");
        -> __end(runner, t);
    }

    state test_meter_description (TestRunner runner, TestContext t) {
        Connection i1         = Connection.NewOhmic("I1");
        SymbolUnit amp        = SymbolUnit.Ampere();
        string amm            = Instrument.Amnmeter();
        InstrumentPort port   = InstrumentPort.NewMeter("I1", i1, amm, amp, "current meter");
        Error err = t.ExpectStrEq("current meter", port.Description(), "Meter description matches");
        -> __end(runner, t);
    }
}

