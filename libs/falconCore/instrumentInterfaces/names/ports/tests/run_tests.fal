// Tests for falconCore/instrumentInterfaces/names/ports
// Run with: falcon-test run_tests.fal
import "../../../../../../testing/testing.fal";
import "../ports.fal";
import "../instrumentPort/instrumentPort.fal";

// JSON fixture: two ports — one knob (P1 voltage), one meter (I1 current)
routine MakeFixtureJSON () -> (string json) {
    json = "{\"ports\":[{\"default_name\":\"P1\",\"pseudo_name\":{\"name\":\"P1\",\"type\":\"PlungerGate\"},\"instrument_type\":\"DCVoltageSource\",\"units\":{\"symbol\":\"V\",\"name\":\"volt\"},\"description\":\"plunger\",\"instrument_facing_name\":\"CH1\",\"is_knob\":true,\"is_meter\":false},{\"default_name\":\"I1\",\"pseudo_name\":{\"name\":\"I1\",\"type\":\"Ohmic\"},\"instrument_type\":\"Amnmeter\",\"units\":{\"symbol\":\"A\",\"name\":\"ampere\"},\"description\":\"ohmic\",\"instrument_facing_name\":\"CURR1\",\"is_knob\":false,\"is_meter\":true}]}";
}

autotuner PortsJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_from_json_to_json_non_empty (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports p  = Ports.FromJSON(fixture);
        string j = p.ToJSON();
        Error err = t.ExpectStrNe("", j, "ToJSON returns non-empty string");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports orig     = Ports.FromJSON(fixture);
        string json    = orig.ToJSON();
        Ports restored = Ports.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "FromJSON(ToJSON(ports)) round-trips");
        -> __end(runner, t);
    }
}

autotuner PortsEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_fixture (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports a = Ports.FromJSON(fixture);
        Ports b = Ports.FromJSON(fixture);
        Error err = t.ExpectTrue(a.Equal(b), "Same fixture gives equal Ports");
        -> __end(runner, t);
    }

    state test_not_equal_different_fixture (TestRunner runner, TestContext t) {
        string fa = "{\"ports\":[{\"default_name\":\"P1\",\"pseudo_name\":{\"name\":\"P1\",\"type\":\"PlungerGate\"},\"instrument_type\":\"DCVoltageSource\",\"units\":{\"symbol\":\"V\",\"name\":\"volt\"},\"description\":\"p\",\"instrument_facing_name\":\"CH1\",\"is_knob\":true,\"is_meter\":false}]}";
        string fb = "{\"ports\":[{\"default_name\":\"B1\",\"pseudo_name\":{\"name\":\"B1\",\"type\":\"BarrierGate\"},\"instrument_type\":\"DCVoltageSource\",\"units\":{\"symbol\":\"V\",\"name\":\"volt\"},\"description\":\"b\",\"instrument_facing_name\":\"CH2\",\"is_knob\":true,\"is_meter\":false}]}";
        Ports a = Ports.FromJSON(fa);
        Ports b = Ports.FromJSON(fb);
        Error err = t.ExpectTrue(a.NotEqual(b), "Different fixtures are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        string fa = "{\"ports\":[{\"default_name\":\"P1\",\"pseudo_name\":{\"name\":\"P1\",\"type\":\"PlungerGate\"},\"instrument_type\":\"DCVoltageSource\",\"units\":{\"symbol\":\"V\",\"name\":\"volt\"},\"description\":\"p\",\"instrument_facing_name\":\"CH1\",\"is_knob\":true,\"is_meter\":false}]}";
        string fb = "{\"ports\":[{\"default_name\":\"B1\",\"pseudo_name\":{\"name\":\"B1\",\"type\":\"BarrierGate\"},\"instrument_type\":\"DCVoltageSource\",\"units\":{\"symbol\":\"V\",\"name\":\"volt\"},\"description\":\"b\",\"instrument_facing_name\":\"CH2\",\"is_knob\":true,\"is_meter\":false}]}";
        Ports a = Ports.FromJSON(fa);
        Ports b = Ports.FromJSON(fb);
        Error err = t.ExpectFalse(a.Equal(b), "Equal is false for different Ports");
        -> __end(runner, t);
    }
}

autotuner PortsBulkAccessors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_get_default_names_length (TestRunner runner, TestContext t) {
        string fixture   = MakeFixtureJSON();
        Ports p          = Ports.FromJSON(fixture);
        Array<string> ns = p.GetDefaultNames();
        Error err = t.ExpectIntEq(2, ns.Size(), "GetDefaultNames has 2 entries");
        -> __end(runner, t);
    }

    state test_get_default_names_values (TestRunner runner, TestContext t) {
        string fixture   = MakeFixtureJSON();
        Ports p          = Ports.FromJSON(fixture);
        Array<string> ns = p.GetDefaultNames();
        Error err = t.ExpectStrEq("P1", ns.Get(0), "First default name is P1");
        err = t.ExpectStrEq("I1", ns.Get(1), "Second default name is I1");
        -> __end(runner, t);
    }

    state test_get_pseudo_names_length (TestRunner runner, TestContext t) {
        string fixture              = MakeFixtureJSON();
        Ports p                     = Ports.FromJSON(fixture);
        Array<connection::Connection> cs = p.GetPsuedoNames();
        Error err = t.ExpectIntEq(2, cs.Size(), "GetPsuedoNames has 2 entries");
        -> __end(runner, t);
    }

    state test_get_pseudo_names_first (TestRunner runner, TestContext t) {
        string fixture              = MakeFixtureJSON();
        Ports p                     = Ports.FromJSON(fixture);
        Array<connection::Connection> cs = p.GetPsuedoNames();
        connection::Connection c0   = cs.Get(0);
        Error err = t.ExpectStrEq("P1", c0.Name(), "First pseudo-name connection is P1");
        -> __end(runner, t);
    }

    state test_is_knobs_length (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports p        = Ports.FromJSON(fixture);
        Array<bool> ks = p.IsKnobs();
        Error err = t.ExpectIntEq(2, ks.Size(), "IsKnobs has 2 entries");
        -> __end(runner, t);
    }

    state test_is_knobs_values (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports p        = Ports.FromJSON(fixture);
        Array<bool> ks = p.IsKnobs();
        Error err = t.ExpectTrue(ks.Get(0),  "Port 0 is a knob");
        err = t.ExpectFalse(ks.Get(1), "Port 1 is not a knob");
        -> __end(runner, t);
    }

    state test_is_meters_length (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports p        = Ports.FromJSON(fixture);
        Array<bool> ms = p.IsMeters();
        Error err = t.ExpectIntEq(2, ms.Size(), "IsMeters has 2 entries");
        -> __end(runner, t);
    }

    state test_is_meters_values (TestRunner runner, TestContext t) {
        string fixture = MakeFixtureJSON();
        Ports p        = Ports.FromJSON(fixture);
        Array<bool> ms = p.IsMeters();
        Error err = t.ExpectFalse(ms.Get(0), "Port 0 is not a meter");
        err = t.ExpectTrue(ms.Get(1),  "Port 1 is a meter");
        -> __end(runner, t);
    }

    state test_ports_array_length (TestRunner runner, TestContext t) {
        string fixture                             = MakeFixtureJSON();
        Ports p                                    = Ports.FromJSON(fixture);
        Array<instrumentPort::InstrumentPort> ps   = p.Ports();
        Error err = t.ExpectIntEq(2, ps.Size(), "Ports() returns 2 entries");
        -> __end(runner, t);
    }

    state test_ports_array_first_name (TestRunner runner, TestContext t) {
        string fixture                             = MakeFixtureJSON();
        Ports p                                    = Ports.FromJSON(fixture);
        Array<instrumentPort::InstrumentPort> ps   = p.Ports();
        instrumentPort::InstrumentPort p0          = ps.Get(0);
        Error err = t.ExpectStrEq("P1", p0.DefaultName(), "First port default name is P1");
        -> __end(runner, t);
    }
}
