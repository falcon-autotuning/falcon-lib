import "../../../../testing/testing.fal";
import "../waveform.fal";

autotuner WaveformJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_roundtrip (TestRunner runner, TestContext t) {
        Waveform orig     = Waveform.FromJSON("{\"polymorphic_id\":2147483649,\"polymorphic_name\":\"falcon_core::instrument_interfaces::Waveform\",\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":{\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":[],\"value1\":{\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":0,\"value1\":1}}},\"value2\":[]}}},\"value1\":[]}}}");
        string          json     = orig.ToJSON();
        Waveform restored = Waveform.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "Waveform JSON roundtrip preserves equality");
        -> __end(runner, t);
    }
}

autotuner WaveformListOps -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_size_and_empty (TestRunner runner, TestContext t) {
        Waveform w = Waveform.FromJSON("{\"polymorphic_id\":2147483649,\"polymorphic_name\":\"falcon_core::instrument_interfaces::Waveform\",\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":{\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":[],\"value1\":{\"ptr_wrapper\":{\"valid\":1,\"data\":{\"value0\":0,\"value1\":1}}},\"value2\":[]}}},\"value1\":[]}}}");
        Error err = t.ExpectTrue(w.IsEmpty(), "Waveform with no transforms is empty");
        -> __end(runner, t);
    }
}
