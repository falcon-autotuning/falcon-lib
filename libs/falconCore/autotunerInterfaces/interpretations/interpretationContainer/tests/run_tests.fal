// Tests for falconCore/autotunerInterfaces/interpretations/interpretationContainer
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../interpretationContainer.fal";
import "../interpretationContext/interpretationContext.fal";
import "../../contexts/measurementContext/measurementContext.fal";
import "../../../../physics/units/symbolUnit/symbolUnit.fal";
import "../../../../physics/deviceStructures/connection/connection.fal";
import "../../../../instrumentInterfaces/names/instrument/instrument.fal";
import "../../../../math/axes/axes.fal";
import "../../../../../collections/map/map.fal";
import "../../../../../collections/array/array.fal";

// ── Helpers ───────────────────────────────────────────────────────────────────

routine MakeMC (string connName, string instType) -> (MeasurementContext mc) {
    Connection conn = Connection.NewPlungerGate(connName);
    mc = MeasurementContext.New(conn, instType);
}

routine MakeCtx () -> (InterpretationContext ctx) {
    MeasurementContext indep = MakeMC("P1", Instrument.DCVoltageSource());
    MeasurementContext dep   = MakeMC("S1", Instrument.Ammeter());
    SymbolUnit volt          = SymbolUnit.Volt();
    Axes<MeasurementContext> axes = Axes<MeasurementContext>.New();
    axes.PushBack(indep);
    Array<MeasurementContext> deps;
    deps.pushback(dep);
    ctx = InterpretationContext.New(axes, deps, volt);
}

// ── Construction ──────────────────────────────────────────────────────────────

autotuner InterpretationContainerConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_from_map (TestRunner runner, TestContext t) {
        InterpretationContext ctx = MakeCtx();
        Map<InterpretationContext, float> contextMap = Map.New();
        contextMap.Set(ctx, 0.5);
        InterpretationContainer ic = InterpretationContainer.New(contextMap);
        string json = ic.ToJSON();
        Error err = t.ExpectStrNe("", json, "New from non-empty Map produces non-empty JSON");
        -> __end(runner, t);
    }
}

// ── Equality ──────────────────────────────────────────────────────────────────

autotuner InterpretationContainerEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_map (TestRunner runner, TestContext t) {
        InterpretationContext ctx = MakeCtx();
        Map<InterpretationContext, float> contextMap = Map.New();
        contextMap.Set(ctx, 0.5);
        InterpretationContainer a = InterpretationContainer.New(contextMap);
        InterpretationContainer b = InterpretationContainer.New(contextMap);
        Error err = t.ExpectTrue(a.Equal(b), "Two containers from the same map are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_values (TestRunner runner, TestContext t) {
        InterpretationContext ctx = MakeCtx();
        Map<InterpretationContext, float> mapWithLowerValue  = Map.New();
        Map<InterpretationContext, float> mapWithHigherValue = Map.New();
        mapWithLowerValue.Set(ctx, 0.5);
        mapWithHigherValue.Set(ctx, 1.5);
        InterpretationContainer a = InterpretationContainer.New(mapWithLowerValue);
        InterpretationContainer b = InterpretationContainer.New(mapWithHigherValue);
        Error err = t.ExpectTrue(a.NotEqual(b), "Containers with different values are not equal");
        -> __end(runner, t);
    }
}

// ── JSON ──────────────────────────────────────────────────────────────────────

autotuner InterpretationContainerJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        InterpretationContext ctx = MakeCtx();
        Map<InterpretationContext, float> contextMap = Map.New();
        contextMap.Set(ctx, 1.0);
        InterpretationContainer ic = InterpretationContainer.New(contextMap);
        string json = ic.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        InterpretationContext ctx = MakeCtx();
        Map<InterpretationContext, float> contextMap = Map.New();
        contextMap.Set(ctx, 1.0);
        InterpretationContainer orig = InterpretationContainer.New(contextMap);
        string json                  = orig.ToJSON();
        InterpretationContainer res  = InterpretationContainer.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(res), "FromJSON(ToJSON(ic)) round-trips");
        -> __end(runner, t);
    }
}
