// Tests for falcon_core/math/analyticFunction
// Run with: falcon-test run_tests.fal
import "../../../../testing/testing.fal";
import "../analyticFunction.fal";

autotuner AnalyticFunctionConstructors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_labels_count (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("a");
        arr.PushBack("b");
        AnalyticFunction f = AnalyticFunction.New(arr, "x[0] + x[1]");
        Array<string> lbls = f.Labels();
        Error err = t.ExpectIntEq(2, lbls.Size(), "New stores two labels");
        -> __end(runner, t);
    }

    state test_identity_creates (TestRunner runner, TestContext t) {
        AnalyticFunction id = AnalyticFunction.Identity();
        string json = id.ToJSON();
        Error err = t.ExpectStrNe("", json, "Identity() produces a valid object");
        -> __end(runner, t);
    }

    state test_constant_creates (TestRunner runner, TestContext t) {
        AnalyticFunction c = AnalyticFunction.Constant(2.5);
        string json = c.ToJSON();
        Error err = t.ExpectStrNe("", json, "Constant() produces a valid object");
        -> __end(runner, t);
    }
}

autotuner AnalyticFunctionLabels -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_labels_first (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("amplitude");
        arr.PushBack("offset");
        AnalyticFunction f = AnalyticFunction.New(arr, "x[0]*t + x[1]");
        Array<string> lbls = f.Labels();
        Error err = t.ExpectStrEq("amplitude", lbls.GetIndex(0), "First label is correct");
        -> __end(runner, t);
    }

    state test_labels_second (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("amplitude");
        arr.PushBack("offset");
        AnalyticFunction f = AnalyticFunction.New(arr, "x[0]*t + x[1]");
        Array<string> lbls = f.Labels();
        Error err = t.ExpectStrEq("offset", lbls.GetIndex(1), "Second label is correct");
        -> __end(runner, t);
    }

    state test_no_labels (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        AnalyticFunction f = AnalyticFunction.New(arr, "1.0");
        Array<string> lbls = f.Labels();
        Error err = t.ExpectIntEq(0, lbls.Size(), "No labels gives empty array");
        -> __end(runner, t);
    }
}

autotuner AnalyticFunctionEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("x");
        AnalyticFunction a = AnalyticFunction.New(arr, "x[0]");
        AnalyticFunction b = AnalyticFunction.New(arr, "x[0]");
        Error err = t.ExpectTrue(a.Equal(b), "Same labels+expression are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_expression (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("x");
        AnalyticFunction a = AnalyticFunction.New(arr, "x[0]");
        AnalyticFunction b = AnalyticFunction.New(arr, "x[0]*2");
        Error err = t.ExpectTrue(a.NotEqual(b), "Different expressions are not equal");
        -> __end(runner, t);
    }

    state test_identity_equal_to_itself (TestRunner runner, TestContext t) {
        AnalyticFunction id = AnalyticFunction.Identity();
        AnalyticFunction id2 = AnalyticFunction.Identity();
        Error err = t.ExpectTrue(id.Equal(id2), "Two Identity() calls are equal");
        -> __end(runner, t);
    }

    state test_constant_equal_to_itself (TestRunner runner, TestContext t) {
        AnalyticFunction c1 = AnalyticFunction.Constant(1.0);
        AnalyticFunction c2 = AnalyticFunction.Constant(1.0);
        Error err = t.ExpectTrue(c1.Equal(c2), "Two Constant(1.0) calls are equal");
        -> __end(runner, t);
    }
}

autotuner AnalyticFunctionJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("a");
        AnalyticFunction f = AnalyticFunction.New(arr, "x[0]");
        string json = f.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Array<string> arr = Array.New();
        arr.PushBack("amplitude");
        arr.PushBack("offset");
        AnalyticFunction orig = AnalyticFunction.New(arr, "x[0]*t + x[1]");
        string json           = orig.ToJSON();
        AnalyticFunction rest = AnalyticFunction.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(rest), "JSON roundtrip preserves equality");
        -> __end(runner, t);
    }

    state test_roundtrip_identity (TestRunner runner, TestContext t) {
        AnalyticFunction orig = AnalyticFunction.Identity();
        string json           = orig.ToJSON();
        AnalyticFunction rest = AnalyticFunction.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(rest), "Identity JSON roundtrip preserves equality");
        -> __end(runner, t);
    }
}
