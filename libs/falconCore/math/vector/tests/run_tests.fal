// Tests for falconCore/math/vector
import "../../../../testing/testing.fal";
import "../vector.fal";
import "../../point/point.fal";

autotuner VectorConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_from_start (TestRunner runner, TestContext t) {
        Point begin= Point.NewFromQuantity(Map.New());
        Vector v = Vector.NewFromStart(begin);
        Error err = t.ExpectTrue(v.Equal(v), "NewFromStart creates a valid vector");
        -> __end(runner, t);
    }

    state test_new_two_points (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Point end   = Point.NewFromQuantity(Map.New());
        Vector v = Vector.New(begin, end);
        Error err = t.ExpectTrue(v.Equal(v), "New(begin, end) creates a valid vector");
        -> __end(runner, t);
    }
}

autotuner VectorMagnitude -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_magnitude_empty_points (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Point end   = Point.NewFromQuantity(Map.New());
        Vector v = Vector.New(begin, end);
        float m = v.Magnitude();
        Error err = t.ExpectFloatEq(0.0, m, 0.001,"Magnitude of empty-point vector is 0.0");
        -> __end(runner, t);
    }
}

autotuner VectorEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_vector (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Point end   = Point.NewFromQuantity(Map.New());
        Vector v = Vector.New(begin, end);
        Error err = t.ExpectTrue(v.Equal(v), "Vector equals itself");
        -> __end(runner, t);
    }

    state test_not_equal_false_for_same (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Vector v = Vector.NewFromStart(begin);
        Error err = t.ExpectFalse(v.NotEqual(v), "NotEqual is false for same vector");
        -> __end(runner, t);
    }
}

autotuner VectorJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Point end   = Point.NewFromQuantity(Map.New());
        Vector v = Vector.New(begin, end);
        string json = v.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON returns non-empty string");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Point begin = Point.NewFromQuantity(Map.New());
        Point end   = Point.NewFromQuantity(Map.New());
        Vector orig = Vector.New(begin, end);
        string json = orig.ToJSON();
        Vector rt = Vector.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(rt), "JSON round-trip preserves equality");
        -> __end(runner, t);
    }
}
