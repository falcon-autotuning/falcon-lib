// Tests for falconCore/math/domains/coupledLabelledDomain
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../coupledLabelledDomain.fal";
import "../../labelledDomain/labelledDomain.fal";
import "../../../../physics/deviceStructures/connection/connection.fal";
import "../../../../physics/units/symbolUnit/symbolUnit.fal";
import "../../../../instrumentInterfaces/names/instrument/instrument.fal";

routine MakeLD () -> (LabelledDomain ld) {
    Connection p1   = Connection.NewPlungerGate("P1");
    SymbolUnit volt = SymbolUnit.Volt();
    string dc       = Instrument.DCVoltageSource();
    ld = LabelledDomain.NewFromKnob("P1", -0.5, 0.5, p1, dc, true, true, volt, "plunger gate");
}

// ── Construction ──────────────────────────────────────────────────────────────

autotuner CoupledLabelledDomainConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_empty (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(empty);
        Error err = t.ExpectTrue(cld.IsEmpty(), "New([]) creates empty CoupledLabelledDomain");
        -> __end(runner, t);
    }

    state test_empty_size_zero (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(empty);
        Error err = t.ExpectEq(0, cld.Size(), "New([]) has size 0");
        -> __end(runner, t);
    }

    state test_with_one_element (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        Error err = t.ExpectEq(1, cld.Size(), "New with one element has size 1");
        -> __end(runner, t);
    }

    state test_with_one_not_empty (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        Error err = t.ExpectFalse(cld.IsEmpty(), "CoupledLabelledDomain with one element is not empty");
        -> __end(runner, t);
    }
}

// ── List operations ───────────────────────────────────────────────────────────

autotuner CoupledLabelledDomainListOps -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_push_back (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(empty);
        LabelledDomain ld = MakeLD();
        cld.PushBack(ld);
        Error err = t.ExpectEq(1, cld.Size(), "PushBack increases size to 1");
        -> __end(runner, t);
    }

    state test_get_index (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        LabelledDomain got        = cld.GetIndex(0);
        Error err = t.ExpectTrue(ld.Equal(got), "GetIndex(0) returns the inserted element");
        -> __end(runner, t);
    }

    state test_clear (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        cld.Clear();
        Error err = t.ExpectTrue(cld.IsEmpty(), "Clear() empties the domain");
        -> __end(runner, t);
    }

    state test_erase (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        cld.Erase(0);
        Error err = t.ExpectTrue(cld.IsEmpty(), "Erase(0) removes the only element");
        -> __end(runner, t);
    }

    state test_contains_true (TestRunner runner, TestContext t) {
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> arr;
        arr.pushback(ld);
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(arr);
        Error err = t.ExpectTrue(cld.Contains(ld), "Contains returns true for inserted element");
        -> __end(runner, t);
    }
}

// ── Equality ──────────────────────────────────────────────────────────────────

autotuner CoupledLabelledDomainEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_empty (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain a = CoupledLabelledDomain.New(empty);
        CoupledLabelledDomain b = CoupledLabelledDomain.New(empty);
        Error err = t.ExpectTrue(a.Equal(b), "Two empty CoupledLabelledDomains are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_sizes (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        LabelledDomain ld = MakeLD();
        Array<LabelledDomain> one;
        one.pushback(ld);
        CoupledLabelledDomain a = CoupledLabelledDomain.New(empty);
        CoupledLabelledDomain b = CoupledLabelledDomain.New(one);
        Error err = t.ExpectTrue(a.NotEqual(b), "Different-size CoupledLabelledDomains are not equal");
        -> __end(runner, t);
    }
}

// ── JSON ──────────────────────────────────────────────────────────────────────

autotuner CoupledLabelledDomainJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain cld = CoupledLabelledDomain.New(empty);
        string json = cld.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Array<LabelledDomain> empty;
        CoupledLabelledDomain orig = CoupledLabelledDomain.New(empty);
        string json                = orig.ToJSON();
        CoupledLabelledDomain res  = CoupledLabelledDomain.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(res), "FromJSON(ToJSON(cld)) round-trips");
        -> __end(runner, t);
    }
}
