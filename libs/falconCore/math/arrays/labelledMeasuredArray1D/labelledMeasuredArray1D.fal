import (
"../measuredArray/measuredArray.fal"
"../../../autotunerInterfaces/acquisitionContext/acquisitionContext.fal"
)
ffimport "labelled-measured-array-1D-wrapper.cpp" ("/opt/falcon/include/falcon_core/") ("/opt/falcon/lib/libfalcon_core_cpp.so")
struct LabelledMeasuredArray1D {
    routine New (FArray arr) -> (LabelledMeasuredArray1D carray)
    routine Add (MeasuredArray other) -> (LabelledMeasuredArray1D carray)
    routine Add (FArray other) -> (LabelledMeasuredArray1D carray)
    routine Add (int other) -> (LabelledMeasuredArray1D carray)
    routine Add (float other) -> (LabelledMeasuredArray1D carray)
    routine Minus (MeasuredArray other) -> (LabelledMeasuredArray1D carray)
    routine Minus (FArray other) -> (LabelledMeasuredArray1D carray)
    routine Minus (int other) -> (LabelledMeasuredArray1D carray)
    routine Minus (float other) -> (LabelledMeasuredArray1D carray)
    routine Negate -> (LabelledMeasuredArray1D carray)
    routine Times (float factor) -> (LabelledMeasuredArray1D carray)
    routine Times (int factor) -> (LabelledMeasuredArray1D carray)
    routine Divides (float factor) -> (LabelledMeasuredArray1D carray)
    routine Divides (int factor) -> (LabelledMeasuredArray1D carray)
    routine Power (float exponent) -> (LabelledMeasuredArray1D carray)
    routine Abs -> (LabelledMeasuredArray1D carray)
    routine Min -> (float min)
    routine Label -> (acquisitionContext::AcquisitionContext ac)
    routine Connection -> (connection::Connection conn)
    routine InstrumentType -> (instrument::Instrument it)
    routine Units -> (symbolUnit::SymbolUnit unit)
    routine GetStart -> (float start)
    routine GetEnd -> (float end)
    routine IsDecreasing -> (bool decreasing)
    routine IsIncreasing -> (bool increasing)
    routine GetDistance -> (float distance)
    routine GetMean -> (float mean)
    routine GetSTD -> (float std)
    routine Reverse -> ()
    routine GetClosestIndex (float value) -> (int index)
    routine EvenDivisions (int divisions) -> (array::Array<farray::FArray> splits)
    // TODO: arraywise min and max
    routine Max -> (float max)
    routine Reshape (Array<int> shape) -> (LabelledMeasuredArray1D carray)
    routine Flip (int axis) -> (LabelledMeasuredArray1D carray)
    routine Gradient (int axis) -> (farray::FArray gradient)
    routine FullGradient -> (Array<farray::FArray> gradients)
    routine Equal (LabelledMeasuredArray1D other) -> (bool equal)
    routine NotEqual (LabelledMeasuredArray1D other) -> (bool notequal)
    routine FromJSON (string json) -> (LabelledMeasuredArray1D farray)
    routine ToJSON () -> (string json)
}
