import (
"../../../generic/farray/farray.fal"
"../increasingAlignment/increasingAlignment.fal"
"../../../autotunerInterfaces/contexts/acquisitionContext/acquisitionContext.fal"
)
ffimport "labelled-control-array-wrapper.cpp" ("/opt/falcon/include/falcon_core/") ("/opt/falcon/lib/libfalcon_core_cpp.so")
struct LabelledControlArray1D {
    routine New (farray::FArray arr) -> (LabelledControlArray1D carray)
    routine Add (ControlArray other) -> (LabelledControlArray1D carray)
    routine Add (farray::FArray other) -> (LabelledControlArray1D carray)
    routine Add (int other) -> (LabelledControlArray1D carray)
    routine Add (float other) -> (LabelledControlArray1D carray)
    routine Minus (LabelledControlArray1D other) -> (LabelledControlArray1D carray)
    routine Minus (farray::FArray other) -> (LabelledControlArray1D carray)
    routine Minus (int other) -> (LabelledControlArray1D carray)
    routine Minus (float other) -> (LabelledControlArray1D carray)
    routine Negate -> (LabelledControlArray1D carray)
    routine Times (float factor) -> (LabelledControlArray1D carray)
    routine Times (int factor) -> (LabelledControlArray1D carray)
    routine Divides (float factor) -> (LabelledControlArray1D carray)
    routine Divides (int factor) -> (LabelledControlArray1D carray)
    routine Power (float exponent) -> (LabelledControlArray1D carray)
    routine Abs -> (LabelledControlArray1D carray)
    routine Min -> (float min)
    routine PrincipleDimension -> (int dim)
    routine Alignment -> (increasingAlignment::IncreasingAlignment alignment)
    routine Label -> (acquisitionContext::AcquisitionContext ac)
    routine Connection -> (connection::Connection conn)
    routine InstrumentType -> (instrument::Instrument it)
    routine Units -> (symbolUnit::SymbolUnit unit)
    routine GetStart -> (float s)
    routine GetEnd -> (float end)
    routine IsDecreasing -> (bool decreasing)
    routine IsIncreasing -> (bool increasing)
    routine GetDistance -> (float distance)
    routine GetMean -> (float mean)
    routine GetSTD -> (float std)
    routine Reverse -> ()
    routine GetClosestIndex (float value) -> (int index)
    routine EvenDivisions (int divisions) -> (array::Array<farray::FArray> splits)
    // TODO: arraywise min and max
    routine Max -> (float max)
    routine Reshape (Array<int> shape) -> (LabelledControlArray1D carray)
    routine Flip (int axis) -> (LabelledControlArray1D carray)
    routine Gradient (int axis) -> (farray::FArray gradient)
    routine FullGradient -> (Array<farray::FArray> gradients)
    routine Equal (LabelledControlArray1D other) -> (bool equal)
    routine NotEqual (LabelledControlArray1D other) -> (bool notequal)
    routine FromJSON (string json) -> (LabelledControlArray1D carray)
    routine ToJSON () -> (string json)
}
