// Tests for falconCore/math/arrays/labelledControlArray1D
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../labelledControlArray1D.fal";
import "../../../../generic/farray/tests/farray-test-helpers.fal";

routine FA (Array<float> vals) -> (farray::FArray arr) {
    arr = FArrayTestHelpers.NewFromFloats(vals);
}

routine LCA1D (Array<float> vals) -> (labelledControlArray1D::LabelledControlArray1D carray) {
    farray::FArray fa = FA(vals);
    carray = labelledControlArray1D::LabelledControlArray1D.New(fa);
}

// ── Construction ──────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_from_farray (TestRunner runner, TestContext t) {
        Array<float> vals; vals.pushback(1.0); vals.pushback(2.0); vals.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D lca = LCA1D(vals);
        string json = lca.ToJSON();
        Error err = t.ExpectStrNe("", json, "New from FArray produces non-empty JSON");
        -> __end(runner, t);
    }
}

// ── Equality ──────────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D b = LCA1D(v);
        Error err = t.ExpectTrue(a.Equal(b), "Same-data LabelledControlArray1Ds are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different (TestRunner runner, TestContext t) {
        Array<float> va; va.pushback(1.0); va.pushback(2.0); va.pushback(3.0);
        Array<float> vb; vb.pushback(1.0); vb.pushback(2.0); vb.pushback(4.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(va);
        labelledControlArray1D::LabelledControlArray1D b = LCA1D(vb);
        Error err = t.ExpectTrue(a.NotEqual(b), "Different-data LabelledControlArray1Ds are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        Array<float> va; va.pushback(1.0); va.pushback(2.0);
        Array<float> vb; vb.pushback(3.0); vb.pushback(4.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(va);
        labelledControlArray1D::LabelledControlArray1D b = LCA1D(vb);
        Error err = t.ExpectFalse(a.Equal(b), "Equal is false for different data");
        -> __end(runner, t);
    }
}

// ── Arithmetic: Times / Divides ───────────────────────────────────────────────

autotuner LabelledControlArray1DScaling -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_times_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(4.0); exp.pushback(6.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Times(2.0);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Times(2.0): [1,2,3]*2=[2,4,6]");
        -> __end(runner, t);
    }

    state test_times_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(3.0); exp.pushback(6.0); exp.pushback(9.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Times(3);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Times(3): [1,2,3]*3=[3,6,9]");
        -> __end(runner, t);
    }

    state test_divides_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(2.0);  v.pushback(4.0);  v.pushback(6.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Divides(2.0);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Divides(2.0): [2,4,6]/2=[1,2,3]");
        -> __end(runner, t);
    }

    state test_divides_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(3.0);  v.pushback(6.0);  v.pushback(9.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Divides(3);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Divides(3): [3,6,9]/3=[1,2,3]");
        -> __end(runner, t);
    }
}

// ── Arithmetic: Add / Minus ───────────────────────────────────────────────────

autotuner LabelledControlArray1DAddMinus -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_add_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Add(1.0);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(1.0): [1,2,3]+1=[2,3,4]");
        -> __end(runner, t);
    }

    state test_add_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(3.0); exp.pushback(4.0); exp.pushback(5.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Add(2);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(2): [1,2,3]+2=[3,4,5]");
        -> __end(runner, t);
    }

    state test_add_lca1d (TestRunner runner, TestContext t) {
        Array<float> va;  va.pushback(1.0); va.pushback(2.0); va.pushback(3.0);
        Array<float> vb;  vb.pushback(1.0); vb.pushback(1.0); vb.pushback(1.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(va);
        labelledControlArray1D::LabelledControlArray1D b   = LCA1D(vb);
        labelledControlArray1D::LabelledControlArray1D res = a.Add(b);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(LabelledControlArray1D): [1,2,3]+[1,1,1]=[2,3,4]");
        -> __end(runner, t);
    }

    state test_minus_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(2.0);  v.pushback(3.0);  v.pushback(4.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Minus(1.0);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Minus(1.0): [2,3,4]-1=[1,2,3]");
        -> __end(runner, t);
    }

    state test_minus_lca1d (TestRunner runner, TestContext t) {
        Array<float> va;  va.pushback(3.0); va.pushback(4.0); va.pushback(5.0);
        Array<float> vb;  vb.pushback(1.0); vb.pushback(1.0); vb.pushback(1.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(va);
        labelledControlArray1D::LabelledControlArray1D b   = LCA1D(vb);
        labelledControlArray1D::LabelledControlArray1D res = a.Minus(b);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Minus(LabelledControlArray1D): [3,4,5]-[1,1,1]=[2,3,4]");
        -> __end(runner, t);
    }
}

// ── Unary ─────────────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DUnary -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_negate (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(-1.0); exp.pushback(-2.0); exp.pushback(-3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Negate();
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Negate: [1,2,3]->[-1,-2,-3]");
        -> __end(runner, t);
    }

    state test_abs_negative (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(-1.0); v.pushback(-2.0); v.pushback(-3.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Abs();
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Abs([-1,-2,-3])=[1,2,3]");
        -> __end(runner, t);
    }

    state test_power_two (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(4.0); exp.pushback(9.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        labelledControlArray1D::LabelledControlArray1D res = a.Power(2.0);
        labelledControlArray1D::LabelledControlArray1D e   = LCA1D(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Power(2.0): [1,2,3]^2=[1,4,9]");
        -> __end(runner, t);
    }
}

// ── Reduction ─────────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DReduction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_min (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(3.0); v.pushback(1.0); v.pushback(2.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float m = a.Min();
        Error err = t.ExpectFloatEq(1.0, m, 1e-9, "Min of [3,1,2] is 1");
        -> __end(runner, t);
    }

    state test_max (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(3.0); v.pushback(1.0); v.pushback(2.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float m = a.Max();
        Error err = t.ExpectFloatEq(3.0, m, 1e-9, "Max of [3,1,2] is 3");
        -> __end(runner, t);
    }
}

// ── 1D accessors ──────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DAccessors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_get_start (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float s = a.GetStart();
        Error err = t.ExpectFloatEq(1.0, s, 1e-9, "GetStart of [1,2,3] is 1");
        -> __end(runner, t);
    }

    state test_get_end (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float e = a.GetEnd();
        Error err = t.ExpectFloatEq(3.0, e, 1e-9, "GetEnd of [1,2,3] is 3");
        -> __end(runner, t);
    }

    state test_is_increasing_true (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        Error err = t.ExpectTrue(a.IsIncreasing(), "[1,2,3] is increasing");
        -> __end(runner, t);
    }

    state test_is_decreasing_false (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        Error err = t.ExpectFalse(a.IsDecreasing(), "[1,2,3] is not decreasing");
        -> __end(runner, t);
    }

    state test_is_decreasing_true (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(3.0); v.pushback(2.0); v.pushback(1.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        Error err = t.ExpectTrue(a.IsDecreasing(), "[3,2,1] is decreasing");
        -> __end(runner, t);
    }

    state test_get_distance (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float d = a.GetDistance();
        Error err = t.ExpectFloatEq(2.0, d, 1e-9, "GetDistance of [1,2,3] is |3-1|=2");
        -> __end(runner, t);
    }

    state test_get_mean (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        float m = a.GetMean();
        Error err = t.ExpectFloatEq(2.0, m, 1e-9, "GetMean of [1,2,3] is 2");
        -> __end(runner, t);
    }

    state test_get_closest_index (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(0.0); v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        int idx = a.GetClosestIndex(1.4);
        Error err = t.ExpectIntEq(1, idx, "GetClosestIndex(1.4) in [0,1,2,3] is 1");
        -> __end(runner, t);
    }
}

// ── Metadata: PrincipleDimension / Alignment ──────────────────────────────────

autotuner LabelledControlArray1DMetadata -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_principle_dimension (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        int dim = a.PrincipleDimension();
        Error err = t.ExpectIntEq(0, dim, "PrincipleDimension of 1D monotone array is 0");
        -> __end(runner, t);
    }

    state test_alignment_increasing (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        increasingAlignment::IncreasingAlignment al = a.Alignment();
        bool inc = al.Alignment();
        Error err = t.ExpectTrue(inc, "Increasing array has increasing alignment");
        -> __end(runner, t);
    }
}

// ── JSON ──────────────────────────────────────────────────────────────────────

autotuner LabelledControlArray1DJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a = LCA1D(v);
        string json = a.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray1D::LabelledControlArray1D a   = LCA1D(v);
        string json                                        = a.ToJSON();
        labelledControlArray1D::LabelledControlArray1D res = labelledControlArray1D::LabelledControlArray1D.FromJSON(json);
        Error err = t.ExpectTrue(a.Equal(res), "FromJSON(ToJSON(a)) round-trips");
        -> __end(runner, t);
    }
}
