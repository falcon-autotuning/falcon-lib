import "../../../../../testing/testing.fal";
import "../increasingAlignment.fal";

autotuner IncreasingAlignmentConstructors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_true_is_increasing (TestRunner runner, TestContext t) {
        IncreasingAlignment ia = IncreasingAlignment.New(true);
        Error err = t.ExpectTrue(ia.Alignment(), "New(true) produces increasing alignment");
        -> __end(runner, t);
    }

    state test_new_false_is_decreasing (TestRunner runner, TestContext t) {
        IncreasingAlignment ia = IncreasingAlignment.New(false);
        Error err = t.ExpectFalse(ia.Alignment(), "New(false) produces decreasing alignment");
        -> __end(runner, t);
    }
}

autotuner IncreasingAlignmentEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_both_increasing (TestRunner runner, TestContext t) {
        IncreasingAlignment a = IncreasingAlignment.New(true);
        IncreasingAlignment b = IncreasingAlignment.New(true);
        Error err = t.ExpectTrue(a.Equal(b), "Two increasing alignments are equal");
        -> __end(runner, t);
    }

    state test_equal_both_decreasing (TestRunner runner, TestContext t) {
        IncreasingAlignment a = IncreasingAlignment.New(false);
        IncreasingAlignment b = IncreasingAlignment.New(false);
        Error err = t.ExpectTrue(a.Equal(b), "Two decreasing alignments are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different (TestRunner runner, TestContext t) {
        IncreasingAlignment a = IncreasingAlignment.New(true);
        IncreasingAlignment b = IncreasingAlignment.New(false);
        Error err = t.ExpectTrue(a.NotEqual(b), "Increasing and decreasing alignments are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        IncreasingAlignment a = IncreasingAlignment.New(true);
        IncreasingAlignment b = IncreasingAlignment.New(false);
        Error err = t.ExpectFalse(a.Equal(b), "Equal returns false for different alignments");
        -> __end(runner, t);
    }

    state test_not_equal_false_for_same (TestRunner runner, TestContext t) {
        IncreasingAlignment a = IncreasingAlignment.New(true);
        IncreasingAlignment b = IncreasingAlignment.New(true);
        Error err = t.ExpectFalse(a.NotEqual(b), "NotEqual returns false for same alignments");
        -> __end(runner, t);
    }
}

autotuner IncreasingAlignmentJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        IncreasingAlignment ia   = IncreasingAlignment.New(true);
        string              json = ia.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip_increasing (TestRunner runner, TestContext t) {
        IncreasingAlignment orig     = IncreasingAlignment.New(true);
        string              json     = orig.ToJSON();
        IncreasingAlignment restored = IncreasingAlignment.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "Increasing alignment roundtrip preserves equality");
        -> __end(runner, t);
    }

    state test_roundtrip_decreasing (TestRunner runner, TestContext t) {
        IncreasingAlignment orig     = IncreasingAlignment.New(false);
        string              json     = orig.ToJSON();
        IncreasingAlignment restored = IncreasingAlignment.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "Decreasing alignment roundtrip preserves equality");
        -> __end(runner, t);
    }

    state test_roundtrip_alignment_value (TestRunner runner, TestContext t) {
        IncreasingAlignment orig     = IncreasingAlignment.New(true);
        string              json     = orig.ToJSON();
        IncreasingAlignment restored = IncreasingAlignment.FromJSON(json);
        Error err = t.ExpectTrue(orig.Alignment() == restored.Alignment(), "Roundtrip preserves Alignment() value");
        -> __end(runner, t);
    }
}
