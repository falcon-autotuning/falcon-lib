// Tests for falconCore/math/arrays/labelledControlArray
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../labelledControlArray.fal";
import "../../../../generic/farray/tests/farray-test-helpers.fal";

routine FA (Array<float> vals) -> (farray::FArray arr) {
    arr = FArrayTestHelpers.NewFromFloats(vals);
}

routine LCA (Array<float> vals) -> (labelledControlArray::LabelledControlArray carray) {
    farray::FArray fa = FA(vals);
    carray = labelledControlArray::LabelledControlArray.New(fa);
}

// ── Construction ──────────────────────────────────────────────────────────────

autotuner LabelledControlArrayConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_from_farray (TestRunner runner, TestContext t) {
        Array<float> vals; vals.pushback(1.0); vals.pushback(2.0); vals.pushback(3.0);
        labelledControlArray::LabelledControlArray lca = LCA(vals);
        string json = lca.ToJSON();
        Error err = t.ExpectStrNe("", json, "New from FArray produces non-empty JSON");
        -> __end(runner, t);
    }
}

// ── Equality ──────────────────────────────────────────────────────────────────

autotuner LabelledControlArrayEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        labelledControlArray::LabelledControlArray b = LCA(v);
        Error err = t.ExpectTrue(a.Equal(b), "Same-data LabelledControlArrays are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different (TestRunner runner, TestContext t) {
        Array<float> va; va.pushback(1.0); va.pushback(2.0); va.pushback(3.0);
        Array<float> vb; vb.pushback(1.0); vb.pushback(2.0); vb.pushback(4.0);
        labelledControlArray::LabelledControlArray a = LCA(va);
        labelledControlArray::LabelledControlArray b = LCA(vb);
        Error err = t.ExpectTrue(a.NotEqual(b), "Different-data LabelledControlArrays are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        Array<float> va; va.pushback(1.0); va.pushback(2.0);
        Array<float> vb; vb.pushback(3.0); vb.pushback(4.0);
        labelledControlArray::LabelledControlArray a = LCA(va);
        labelledControlArray::LabelledControlArray b = LCA(vb);
        Error err = t.ExpectFalse(a.Equal(b), "Equal is false for different data");
        -> __end(runner, t);
    }
}

// ── Arithmetic: Times / Divides ───────────────────────────────────────────────

autotuner LabelledControlArrayScaling -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_times_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(4.0); exp.pushback(6.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Times(2.0);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Times(2.0): [1,2,3]*2=[2,4,6]");
        -> __end(runner, t);
    }

    state test_times_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(3.0); exp.pushback(6.0); exp.pushback(9.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Times(3);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Times(3): [1,2,3]*3=[3,6,9]");
        -> __end(runner, t);
    }

    state test_divides_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(2.0);  v.pushback(4.0);  v.pushback(6.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Divides(2.0);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Divides(2.0): [2,4,6]/2=[1,2,3]");
        -> __end(runner, t);
    }

    state test_divides_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(3.0);  v.pushback(6.0);  v.pushback(9.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Divides(3);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Divides(3): [3,6,9]/3=[1,2,3]");
        -> __end(runner, t);
    }
}

// ── Arithmetic: Add / Minus ───────────────────────────────────────────────────

autotuner LabelledControlArrayAddMinus -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_add_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Add(1.0);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(1.0): [1,2,3]+1=[2,3,4]");
        -> __end(runner, t);
    }

    state test_add_int (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(3.0); exp.pushback(4.0); exp.pushback(5.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Add(2);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(2): [1,2,3]+2=[3,4,5]");
        -> __end(runner, t);
    }

    state test_add_lca (TestRunner runner, TestContext t) {
        Array<float> va;  va.pushback(1.0); va.pushback(2.0); va.pushback(3.0);
        Array<float> vb;  vb.pushback(1.0); vb.pushback(1.0); vb.pushback(1.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray::LabelledControlArray a   = LCA(va);
        labelledControlArray::LabelledControlArray b   = LCA(vb);
        labelledControlArray::LabelledControlArray res = a.Add(b);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(LabelledControlArray): [1,2,3]+[1,1,1]=[2,3,4]");
        -> __end(runner, t);
    }

    state test_add_farray (TestRunner runner, TestContext t) {
        Array<float> va;  va.pushback(1.0); va.pushback(2.0); va.pushback(3.0);
        Array<float> vb;  vb.pushback(0.0); vb.pushback(0.0); vb.pushback(1.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(4.0);
        labelledControlArray::LabelledControlArray a   = LCA(va);
        farray::FArray                             fb  = FA(vb);
        labelledControlArray::LabelledControlArray res = a.Add(fb);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Add(FArray): [1,2,3]+[0,0,1]=[1,2,4]");
        -> __end(runner, t);
    }

    state test_minus_float (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(2.0);  v.pushback(3.0);  v.pushback(4.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Minus(1.0);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Minus(1.0): [2,3,4]-1=[1,2,3]");
        -> __end(runner, t);
    }

    state test_minus_lca (TestRunner runner, TestContext t) {
        Array<float> va;  va.pushback(3.0); va.pushback(4.0); va.pushback(5.0);
        Array<float> vb;  vb.pushback(1.0); vb.pushback(1.0); vb.pushback(1.0);
        Array<float> exp; exp.pushback(2.0); exp.pushback(3.0); exp.pushback(4.0);
        labelledControlArray::LabelledControlArray a   = LCA(va);
        labelledControlArray::LabelledControlArray b   = LCA(vb);
        labelledControlArray::LabelledControlArray res = a.Minus(b);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Minus(LabelledControlArray): [3,4,5]-[1,1,1]=[2,3,4]");
        -> __end(runner, t);
    }
}

// ── Unary ─────────────────────────────────────────────────────────────────────

autotuner LabelledControlArrayUnary -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_negate (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(-1.0); exp.pushback(-2.0); exp.pushback(-3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Negate();
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Negate: [1,2,3]->[-1,-2,-3]");
        -> __end(runner, t);
    }

    state test_abs_negative (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(-1.0); v.pushback(-2.0); v.pushback(-3.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(2.0); exp.pushback(3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Abs();
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Abs([-1,-2,-3])=[1,2,3]");
        -> __end(runner, t);
    }

    state test_power_two (TestRunner runner, TestContext t) {
        Array<float> v;   v.pushback(1.0);  v.pushback(2.0);  v.pushback(3.0);
        Array<float> exp; exp.pushback(1.0); exp.pushback(4.0); exp.pushback(9.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        labelledControlArray::LabelledControlArray res = a.Power(2.0);
        labelledControlArray::LabelledControlArray e   = LCA(exp);
        Error err = t.ExpectTrue(res.Equal(e), "Power(2.0): [1,2,3]^2=[1,4,9]");
        -> __end(runner, t);
    }
}

// ── Reduction ─────────────────────────────────────────────────────────────────

autotuner LabelledControlArrayReduction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_min (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(3.0); v.pushback(1.0); v.pushback(2.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        float m = a.Min();
        Error err = t.ExpectFloatEq(1.0, m, 1e-9, "Min of [3,1,2] is 1");
        -> __end(runner, t);
    }

    state test_max (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(3.0); v.pushback(1.0); v.pushback(2.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        float m = a.Max();
        Error err = t.ExpectFloatEq(3.0, m, 1e-9, "Max of [3,1,2] is 3");
        -> __end(runner, t);
    }
}

// ── Metadata: PrincipleDimension / Alignment ──────────────────────────────────

autotuner LabelledControlArrayMetadata -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_principle_dimension (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        int dim = a.PrincipleDimension();
        Error err = t.ExpectIntEq(0, dim, "PrincipleDimension of 1D monotone array is 0");
        -> __end(runner, t);
    }

    state test_alignment_non_null_json (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        increasingAlignment::IncreasingAlignment al = a.Alignment();
        string json = al.ToJSON();
        Error err = t.ExpectStrNe("", json, "Alignment of monotone array is non-null");
        -> __end(runner, t);
    }

    state test_alignment_increasing (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        increasingAlignment::IncreasingAlignment al = a.Alignment();
        bool inc = al.Alignment();
        Error err = t.ExpectTrue(inc, "Increasing array has increasing alignment");
        -> __end(runner, t);
    }
}

// ── JSON ──────────────────────────────────────────────────────────────────────

autotuner LabelledControlArrayJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a = LCA(v);
        string json = a.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        Array<float> v; v.pushback(1.0); v.pushback(2.0); v.pushback(3.0);
        labelledControlArray::LabelledControlArray a   = LCA(v);
        string json                                    = a.ToJSON();
        labelledControlArray::LabelledControlArray res = labelledControlArray::LabelledControlArray.FromJSON(json);
        Error err = t.ExpectTrue(a.Equal(res), "FromJSON(ToJSON(a)) round-trips");
        -> __end(runner, t);
    }
}
