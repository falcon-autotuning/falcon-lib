// Tests for falconCore/communications/voltageStates/deviceVoltageStates
// Run with: falcon-test run_tests.fal
import "../../../../../testing/testing.fal";
import "../deviceVoltageStates.fal";
import "../../deviceVoltageState/deviceVoltageState.fal";
import "../../../../physics/deviceStructures/connection/connection.fal";
import "../../../../physics/units/symbolUnit/symbolUnit.fal";

routine MakeDVS (string name, float voltage) -> (DeviceVoltageState dvs) {
    Connection c  = Connection.NewPlungerGate(name);
    SymbolUnit v  = SymbolUnit.Volt();
    dvs           = DeviceVoltageState.New(c, voltage, v);
}

autotuner DeviceVoltageStatesConstruction -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_empty (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectTrue(s.Empty(), "New from empty array is empty");
        -> __end(runner, t);
    }

    state test_new_size_zero (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectIntEq(0, s.Size(), "Empty size is 0");
        -> __end(runner, t);
    }

    state test_new_single (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 0.5);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectIntEq(1, s.Size(), "Single-entry size is 1");
        -> __end(runner, t);
    }

    state test_new_two (TestRunner runner, TestContext t) {
        DeviceVoltageState d1 = MakeDVS("P1", 0.5);
        DeviceVoltageState d2 = MakeDVS("P2", 1.0);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d1);
        arr.PushBack(d2);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectIntEq(2, s.Size(), "Two-entry size is 2");
        -> __end(runner, t);
    }

    state test_not_empty_when_populated (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 1.0);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectFalse(s.Empty(), "Non-empty states returns false for Empty");
        -> __end(runner, t);
    }
}

autotuner DeviceVoltageStatesMutators -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_add_state (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        DeviceVoltageState d  = MakeDVS("P1", 0.5);
        s.AddState(d);
        Error err = t.ExpectIntEq(1, s.Size(), "Size is 1 after AddState");
        -> __end(runner, t);
    }

    state test_add_two_states (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        s.AddState(MakeDVS("P1", 0.5));
        s.AddState(MakeDVS("P2", 1.0));
        Error err = t.ExpectIntEq(2, s.Size(), "Size is 2 after two AddStates");
        -> __end(runner, t);
    }

    state test_clear (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 0.5);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        s.Clear();
        Error err = t.ExpectTrue(s.Empty(), "Empty after Clear");
        -> __end(runner, t);
    }

    state test_clear_size_zero (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 0.5);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        s.Clear();
        Error err = t.ExpectIntEq(0, s.Size(), "Size is 0 after Clear");
        -> __end(runner, t);
    }
}

autotuner DeviceVoltageStatesAccessors -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_contains_present (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 0.5);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectTrue(s.Contains(d), "Contains P1 returns true");
        -> __end(runner, t);
    }

    state test_contains_absent (TestRunner runner, TestContext t) {
        DeviceVoltageState d1  = MakeDVS("P1", 0.5);
        DeviceVoltageState d2  = MakeDVS("P2", 0.5);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d1);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        Error err = t.ExpectFalse(s.Contains(d2), "Contains P2 returns false when absent");
        -> __end(runner, t);
    }

    state test_find_state_voltage (TestRunner runner, TestContext t) {
        Connection p1         = Connection.NewPlungerGate("P1");
        SymbolUnit volt       = SymbolUnit.Volt();
        DeviceVoltageState d  = DeviceVoltageState.New(p1, 0.75, volt);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        DeviceVoltageState found = s.FindState(p1);
        Error err = t.ExpectFloatEq(0.75, found.Voltage(), 1e-9, "FindState returns correct voltage");
        -> __end(runner, t);
    }

    state test_size_after_add (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        s.AddState(MakeDVS("P1", 1.0));
        s.AddState(MakeDVS("P2", 2.0));
        s.AddState(MakeDVS("P3", 3.0));
        Error err = t.ExpectIntEq(3, s.Size(), "Size is 3 after 3 AddStates");
        -> __end(runner, t);
    }
}

autotuner DeviceVoltageStatesEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same (TestRunner runner, TestContext t) {
        DeviceVoltageState d1 = MakeDVS("P1", 1.0);
        DeviceVoltageState d2 = MakeDVS("P1", 1.0);
        Array<DeviceVoltageState> arr1 = Array.New();
        arr1.PushBack(d1);
        Array<DeviceVoltageState> arr2 = Array.New();
        arr2.PushBack(d2);
        DeviceVoltageStates a = DeviceVoltageStates.New(arr1);
        DeviceVoltageStates b = DeviceVoltageStates.New(arr2);
        Error err = t.ExpectTrue(a.Equal(b), "Same states are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different (TestRunner runner, TestContext t) {
        DeviceVoltageState d1 = MakeDVS("P1", 1.0);
        DeviceVoltageState d2 = MakeDVS("P1", 2.0);
        Array<DeviceVoltageState> arr1 = Array.New();
        arr1.PushBack(d1);
        Array<DeviceVoltageState> arr2 = Array.New();
        arr2.PushBack(d2);
        DeviceVoltageStates a = DeviceVoltageStates.New(arr1);
        DeviceVoltageStates b = DeviceVoltageStates.New(arr2);
        Error err = t.ExpectTrue(a.NotEqual(b), "Different voltages are not equal");
        -> __end(runner, t);
    }

    state test_equal_empty (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates a = DeviceVoltageStates.New(arr);
        DeviceVoltageStates b = DeviceVoltageStates.New(arr);
        Error err = t.ExpectTrue(a.Equal(b), "Two empty states are equal");
        -> __end(runner, t);
    }

    state test_equal_false_different (TestRunner runner, TestContext t) {
        DeviceVoltageState d1 = MakeDVS("P1", 0.5);
        DeviceVoltageState d2 = MakeDVS("P2", 0.5);
        Array<DeviceVoltageState> arr1 = Array.New();
        arr1.PushBack(d1);
        Array<DeviceVoltageState> arr2 = Array.New();
        arr2.PushBack(d2);
        DeviceVoltageStates a = DeviceVoltageStates.New(arr1);
        DeviceVoltageStates b = DeviceVoltageStates.New(arr2);
        Error err = t.ExpectFalse(a.Equal(b), "Equal false for different connections");
        -> __end(runner, t);
    }
}

autotuner DeviceVoltageStatesJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        DeviceVoltageState d  = MakeDVS("P1", 1.0);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d);
        DeviceVoltageStates s = DeviceVoltageStates.New(arr);
        string json = s.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        DeviceVoltageState d1 = MakeDVS("P1", 0.5);
        DeviceVoltageState d2 = MakeDVS("P2", 1.0);
        Array<DeviceVoltageState> arr = Array.New();
        arr.PushBack(d1);
        arr.PushBack(d2);
        DeviceVoltageStates orig    = DeviceVoltageStates.New(arr);
        string json                 = orig.ToJSON();
        DeviceVoltageStates restored = DeviceVoltageStates.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "FromJSON(ToJSON()) round-trips");
        -> __end(runner, t);
    }

    state test_roundtrip_empty (TestRunner runner, TestContext t) {
        Array<DeviceVoltageState> arr = Array.New();
        DeviceVoltageStates orig     = DeviceVoltageStates.New(arr);
        string json                  = orig.ToJSON();
        DeviceVoltageStates restored = DeviceVoltageStates.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "Empty round-trips via JSON");
        -> __end(runner, t);
    }
}
