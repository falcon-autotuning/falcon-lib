import (
"../../../instrumentInterfaces/waveform/waveform.fal"
"../../../math/domains/labelledDomain/labelledDomain.fal"
)
ffimport "measurement-request-wrapper.cpp" ("/opt/falcon/include/falcon_core/") ("/opt/falcon/lib/libfalcon_core_cpp.so")
struct MeasurementRequest { 
    routine New (string message, string measurement_name, array::Array<waveform::Waveform> waveforms, ports::Ports getters, map::Map<instrumentPort::InstrumentPort, portTransform::PortTransform> meterTransforms, labelledDomain::LabelledDomain timeDomain) -> (MeasurementRequest request)
    routine MeasurementName -> (string name)
    routine Getters -> (ports::Ports ports)
    routine Waveforms -> (array::Array<waveform::Waveform> waveforms)
    routine MeterTransforms -> (map::Map<instrumentPort::InstrumentPort, portTransform::PortTransform> map)
    routine TimeDomain -> (labelledDomain::LabelledDomain domain)
    routine Equal (PortTransforms other) -> (bool equal)
    routine NotEqual (PortTransforms other) -> (bool notequal)
    routine FromJSON (string json) -> (PortTransforms transforms)
    routine ToJSON -> (string json)
    routine Message -> (string message)
}
