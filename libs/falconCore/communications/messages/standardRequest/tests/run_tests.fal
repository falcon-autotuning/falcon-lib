import "../../../../../testing/testing.fal";
import "../standardRequest.fal";

autotuner StandardRequestConstructor -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_message (TestRunner runner, TestContext t) {
        StandardRequest req = StandardRequest.New("hello");
        Error err = t.ExpectStrEq("hello", req.Message(), "StandardRequest.New stores message");
        -> __end(runner, t);
    }

    state test_new_empty_message (TestRunner runner, TestContext t) {
        StandardRequest req = StandardRequest.New("");
        Error err = t.ExpectStrEq("", req.Message(), "StandardRequest.New stores empty message");
        -> __end(runner, t);
    }
}

autotuner StandardRequestEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_message (TestRunner runner, TestContext t) {
        StandardRequest a = StandardRequest.New("hello");
        StandardRequest b = StandardRequest.New("hello");
        Error err = t.ExpectTrue(a.Equal(b), "Same-message requests are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_messages (TestRunner runner, TestContext t) {
        StandardRequest a = StandardRequest.New("hello");
        StandardRequest b = StandardRequest.New("world");
        Error err = t.ExpectTrue(a.NotEqual(b), "Different-message requests are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        StandardRequest a = StandardRequest.New("foo");
        StandardRequest b = StandardRequest.New("bar");
        Error err = t.ExpectFalse(a.Equal(b), "Equal returns false for different messages");
        -> __end(runner, t);
    }

    state test_not_equal_false_for_same (TestRunner runner, TestContext t) {
        StandardRequest a = StandardRequest.New("same");
        StandardRequest b = StandardRequest.New("same");
        Error err = t.ExpectFalse(a.NotEqual(b), "NotEqual returns false for same messages");
        -> __end(runner, t);
    }
}

autotuner StandardRequestJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        StandardRequest req  = StandardRequest.New("hello");
        string          json = req.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        StandardRequest orig     = StandardRequest.New("hello");
        string          json     = orig.ToJSON();
        StandardRequest restored = StandardRequest.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "StandardRequest JSON roundtrip preserves equality");
        -> __end(runner, t);
    }

    state test_roundtrip_message (TestRunner runner, TestContext t) {
        StandardRequest orig     = StandardRequest.New("test payload");
        string          json     = orig.ToJSON();
        StandardRequest restored = StandardRequest.FromJSON(json);
        Error err = t.ExpectStrEq(orig.Message(), restored.Message(), "Roundtrip preserves message");
        -> __end(runner, t);
    }
}
