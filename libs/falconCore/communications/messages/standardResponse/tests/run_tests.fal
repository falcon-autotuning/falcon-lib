import "../../../../../testing/testing.fal";
import "../standardResponse.fal";

autotuner StandardResponseConstructor -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_new_message (TestRunner runner, TestContext t) {
        StandardResponse resp = StandardResponse.New("ok");
        Error err = t.ExpectStrEq("ok", resp.Message(), "StandardResponse.New stores message");
        -> __end(runner, t);
    }

    state test_new_empty_message (TestRunner runner, TestContext t) {
        StandardResponse resp = StandardResponse.New("");
        Error err = t.ExpectStrEq("", resp.Message(), "StandardResponse.New stores empty message");
        -> __end(runner, t);
    }
}

autotuner StandardResponseEquality -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_equal_same_message (TestRunner runner, TestContext t) {
        StandardResponse a = StandardResponse.New("ok");
        StandardResponse b = StandardResponse.New("ok");
        Error err = t.ExpectTrue(a.Equal(b), "Same-message responses are equal");
        -> __end(runner, t);
    }

    state test_not_equal_different_messages (TestRunner runner, TestContext t) {
        StandardResponse a = StandardResponse.New("ok");
        StandardResponse b = StandardResponse.New("error");
        Error err = t.ExpectTrue(a.NotEqual(b), "Different-message responses are not equal");
        -> __end(runner, t);
    }

    state test_equal_false_for_different (TestRunner runner, TestContext t) {
        StandardResponse a = StandardResponse.New("foo");
        StandardResponse b = StandardResponse.New("bar");
        Error err = t.ExpectFalse(a.Equal(b), "Equal returns false for different messages");
        -> __end(runner, t);
    }

    state test_not_equal_false_for_same (TestRunner runner, TestContext t) {
        StandardResponse a = StandardResponse.New("same");
        StandardResponse b = StandardResponse.New("same");
        Error err = t.ExpectFalse(a.NotEqual(b), "NotEqual returns false for same messages");
        -> __end(runner, t);
    }
}

autotuner StandardResponseJSON -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_to_json_non_empty (TestRunner runner, TestContext t) {
        StandardResponse resp = StandardResponse.New("ok");
        string           json = resp.ToJSON();
        Error err = t.ExpectStrNe("", json, "ToJSON is non-empty");
        -> __end(runner, t);
    }

    state test_roundtrip (TestRunner runner, TestContext t) {
        StandardResponse orig     = StandardResponse.New("ok");
        string           json     = orig.ToJSON();
        StandardResponse restored = StandardResponse.FromJSON(json);
        Error err = t.ExpectTrue(orig.Equal(restored), "StandardResponse JSON roundtrip preserves equality");
        -> __end(runner, t);
    }

    state test_roundtrip_message (TestRunner runner, TestContext t) {
        StandardResponse orig     = StandardResponse.New("test payload");
        string           json     = orig.ToJSON();
        StandardResponse restored = StandardResponse.FromJSON(json);
        Error err = t.ExpectStrEq(orig.Message(), restored.Message(), "Roundtrip preserves message");
        -> __end(runner, t);
    }
}
