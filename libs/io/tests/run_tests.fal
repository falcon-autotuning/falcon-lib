// Tests for the falcon/io library.
import "../../testing/testing.fal";
import "../../strings/strings.fal";
import "../io.fal";

// ─────────────────────────────────────────────────────────────────────────────
// Suite 1: Top-level write routines
// ─────────────────────────────────────────────────────────────────────────────
autotuner WriteRoutineTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    // Print / Println do not crash and return no error value we can assert on
    // beyond the capture confirming the text appeared on stdout.

    state test_println_appears_on_stdout (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        err           = Println("hello-println");
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool   ok     = Contains(plain, "hello-println");
        err           = t.ExpectTrue(ok, "Println: text reaches stdout");
        -> __end(runner, t);
    }

    state test_print_no_newline (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        err           = Print("no-newline");
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool   has    = Contains(plain, "no-newline");
        err           = t.ExpectTrue(has, "Print: text captured without forced newline");
        -> __end(runner, t);
    }

    state test_eprintln_appears_on_stderr (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStderr();
        err           = Eprintln("hello-stderr");
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool   ok     = Contains(plain, "hello-stderr");
        err           = t.ExpectTrue(ok, "Eprintln: text reaches stderr");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 2: IOCapture lifecycle
// ─────────────────────────────────────────────────────────────────────────────
autotuner CaptureLifecycleTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_is_active_false_initially (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        bool active   = cap.IsActive();
        Error err     = t.ExpectFalse(active, "IsActive is false before Begin");
        -> __end(runner, t);
    }

    state test_is_active_true_during_capture (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        bool active   = cap.IsActive();
        err           = t.ExpectTrue(active, "IsActive is true after BeginStdout");
        string _discard = cap.End();
        -> __end(runner, t);
    }

    state test_captured_string_contains_output (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        err           = Println("capture-marker-42");
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool   ok     = Contains(plain, "capture-marker-42");
        err           = t.ExpectTrue(ok, "Captured string contains written text");
        -> __end(runner, t);
    }

    state test_multiple_writes_all_captured (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        err           = Println("line-a");
        err           = Println("line-b");
        err           = Println("line-c");
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool has_a    = Contains(plain, "line-a");
        bool has_b    = Contains(plain, "line-b");
        bool has_c    = Contains(plain, "line-c");
        err           = t.ExpectTrue(has_a, "Multiple writes: line-a present");
        err           = t.ExpectTrue(has_b, "Multiple writes: line-b present");
        err           = t.ExpectTrue(has_c, "Multiple writes: line-c present");
        -> __end(runner, t);
    }

    state test_empty_capture (TestRunner runner, TestContext t) {
        IOCapture cap = IOCapture.New();
        Error err     = cap.BeginStdout();
        string out    = cap.End();
        string plain  = StripAnsi(out);
        bool   empty  = IsEmpty(plain);
        err           = t.ExpectTrue(empty, "End with no writes yields empty string");
        -> __end(runner, t);
    }

    state test_write_stdout_bypasses_capture (TestRunner runner, TestContext t) {
        IOCapture cap    = IOCapture.New();
        Error err        = cap.BeginStdout();
        err              = cap.WriteStdout("bypass-text\n");
        string captured  = cap.End();
        string plain     = StripAnsi(captured);
        // bypass text went to the real fd, not through the pipe
        bool in_capture  = Contains(plain, "bypass-text");
        err              = t.ExpectFalse(in_capture, "WriteStdout bypasses capture pipe");
        -> __end(runner, t);
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Suite 3: Peek
// ─────────────────────────────────────────────────────────────────────────────
autotuner PeekTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    state test_peek_partial (TestRunner runner, TestContext t) {
        IOCapture cap  = IOCapture.New();
        Error err      = cap.BeginStdout();
        err            = Println("peek-line");
        string peeked  = cap.Peek();
        string plain   = StripAnsi(peeked);
        bool   ok      = Contains(plain, "peek-line");
        err            = t.ExpectTrue(ok, "Peek: sees text before End is called");
        string _discard = cap.End();
        -> __end(runner, t);
    }

    state test_peek_then_more_writes (TestRunner runner, TestContext t) {
        IOCapture cap   = IOCapture.New();
        Error err       = cap.BeginStdout();
        err             = Println("before-peek");
        string _peek    = cap.Peek();
        err             = Println("after-peek");
        string final    = cap.End();
        string plain    = StripAnsi(final);
        bool has_before = Contains(plain, "before-peek");
        bool has_after  = Contains(plain, "after-peek");
        err             = t.ExpectTrue(has_before, "Peek+End: before-peek in final");
        err             = t.ExpectTrue(has_after,  "Peek+End: after-peek in final");
        -> __end(runner, t);
    }
}
