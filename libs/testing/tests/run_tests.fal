import "test_self.fal"

// RunAllTests exercises one representative assertion inline.
// Autotuners cannot be called as sub-routines in Falcon, so each test
// is inlined here using TestContext directly rather than delegating to the
// autotuners defined in test_self.fal.
autotuner RunAllTests -> (int passed, int failed) {
  passed = 0;
  failed = 0;

  start -> run_expect_true_pass;

  state run_expect_true_pass {
    TestContext t = TestContext.New("ExpectTrue-pass");
    t.ExpectTrue(true, "true should pass");
    bool p = t.Passed();
    if (p) -> inc_passed;
    else -> inc_failed;
  }

  state inc_passed {
    passed = passed + 1;
    -> done;
  }

  state inc_failed {
    failed = failed + 1;
    -> done;
  }

  state done { terminal; }
}
