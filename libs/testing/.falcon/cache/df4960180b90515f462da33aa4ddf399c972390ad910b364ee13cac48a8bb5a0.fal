import "../../libs/testing/testing.fal"

// ─── Test 1: basic pass ───────────────────────────────────────────────────────
autotuner TestExpectTruePass -> (bool overall_passed) {
  overall_passed = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("ExpectTrue-pass");
    t.ExpectTrue(true, "true should pass");
    overall_passed = t.Passed();
    -> done;
  }

  state done { terminal; }
}

// ─── Test 2: basic fail ───────────────────────────────────────────────────────
autotuner TestExpectTrueFail -> (bool recorded_failure) {
  recorded_failure = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("ExpectTrue-fail");
    t.ExpectTrue(false, "false should record failure");
    int fc = t.FailureCount();
    recorded_failure = (fc > 0);
    -> done;
  }

  state done { terminal; }
}

// ─── Test 3: IntEq pass ───────────────────────────────────────────────────────
autotuner TestIntEqPass -> (bool passed) {
  passed = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("IntEq-pass");
    t.ExpectIntEq(42, 42, "42 == 42");
    passed = t.Passed();
    -> done;
  }

  state done { terminal; }
}

// ─── Test 4: IntEq fail ───────────────────────────────────────────────────────
autotuner TestIntEqFail -> (bool recorded) {
  recorded = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("IntEq-fail");
    t.ExpectIntEq(1, 2, "1 != 2 should fail");
    int fc = t.FailureCount();
    recorded = (fc > 0);
    -> done;
  }

  state done { terminal; }
}

// ─── Test 5: Suite aggregation ────────────────────────────────────────────────
autotuner TestSuiteAggregation -> (int total, int passed_count, int failed_count) {
  total = 0;
  passed_count = 0;
  failed_count = 0;

  start -> build_suite;

  state build_suite {
    TestSuite suite = TestSuite.New("aggregate-suite");

    TestContext t1 = TestContext.New("pass-test");
    t1.ExpectTrue(true, "should pass");

    TestContext t2 = TestContext.New("fail-test");
    t2.ExpectTrue(false, "should fail");

    suite.AddResult(t1);
    suite.AddResult(t2);

    total        = suite.TotalCount();
    passed_count = suite.PassedCount();
    failed_count = suite.FailedCount();

    suite.PrintSummary();
    -> done;
  }

  state done { terminal; }
}

// ─── Test 6: Float equality ───────────────────────────────────────────────────
autotuner TestFloatEq -> (bool passed) {
  passed = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("FloatEq");
    t.ExpectFloatEq(3.14, 3.14, 0.001, "pi == pi within tol");
    passed = t.Passed();
    -> done;
  }

  state done { terminal; }
}

// ─── Test 7: String equality ──────────────────────────────────────────────────
autotuner TestStrEq -> (bool passed) {
  passed = false;

  start -> run;

  state run {
    TestContext t = TestContext.New("StrEq");
    t.ExpectStrEq("hello", "hello", "same string");
    passed = t.Passed();
    -> done;
  }

  state done { terminal; }
}

// ─── Test 8: Fixture pattern ──────────────────────────────────────────────────
// Demonstrates the "fixture" idiom: a shared TestContext is passed through
// multiple states (simulating setup → test → teardown).
autotuner TestFixturePattern -> (bool all_passed) {
  all_passed = false;

  start -> setup;

  state setup {
    TestContext ctx = TestContext.New("fixture-pattern");
    ctx.Log("fixture: setup complete");
    -> verify_step_one(ctx);
  }

  state verify_step_one (TestContext ctx) {
    ctx.ExpectIntEq(1, 1, "step 1: 1==1");
    ctx.Log("fixture: step one done");
    -> verify_step_two(ctx);
  }

  state verify_step_two (TestContext ctx) {
    ctx.ExpectStrEq("falcon", "falcon", "step 2: strings match");
    ctx.Log("fixture: step two done");
    -> teardown(ctx);
  }

  state teardown (TestContext ctx) {
    ctx.Log("fixture: teardown");
    all_passed = ctx.Passed();
    -> done;
  }

  state done { terminal; }
}
